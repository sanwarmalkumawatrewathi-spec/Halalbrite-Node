<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Halalbrite Admin Dashboard</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <!-- Custom Style -->
    <!-- Custom Style -->
    <link rel="stylesheet" href="/css/modern-admin.css">
    <%- style %>
</head>

<body>
    <!-- Sidebar -->
    <aside id="mySidebar" class="sidebar">
        <a href="/admin/dashboard" class="logo  desktoplogo">
            <img src="/images/logo.svg" alt="HalalBrite">
            <span>Halal Brite</span>
        </a>

        <nav class="sidebar-nav">
            <a href="/admin/dashboard" class="nav-item <%= activePage === 'dashboard' ? 'active' : '' %>"
                title="Dashboard">
                <i class="fa-solid fa-chart-line"></i>
                <span>Dashboard</span>
            </a>
            <a href="/admin/users" class="nav-item <%= activePage === 'users' ? 'active' : '' %>" title="Users">
                <i class="fa-solid fa-users"></i>
                <span>Users</span>
            </a>
            <a href="/admin/events" class="nav-item <%= activePage === 'events' ? 'active' : '' %>" title="Events">
                <i class="fa-solid fa-calendar-days"></i>
                <span>Events</span>
            </a>
            <a href="/admin/categories" class="nav-item <%= activePage === 'categories' ? 'active' : '' %>"
                title="Categories">
                <i class="fa-solid fa-tags"></i>
                <span>Categories</span>
            </a>
            <a href="/admin/orders" class="nav-item <%= activePage === 'orders' ? 'active' : '' %>" title="Orders">
                <i class="fa-solid fa-receipt"></i>
                <span>Orders</span>
            </a>



            <div class="nav-item-wrapper">
                <div class="nav-item <%= activePage === 'stripe' ? 'active' : '' %>" title="Stripe Connect"
                    onclick="toggleSubmenu('stripe-submenu')">
                    <i class="fa-solid fa-money-bill-transfer"></i>
                    <span>Stripe Connect</span>
                    <i class="fa-solid fa-chevron-down submenu-arrow"
                        style="<%= activePage === 'stripe' ? 'transform: rotate(180deg);' : '' %>"></i>
                </div>
                <div class="submenu" id="stripe-submenu"
                    style="<%= activePage === 'stripe' ? 'display: block;' : 'display: none;' %>">
                    <a href="/admin/stripe/dashboard"
                        class="submenu-item <%= (typeof activeSubPage !== 'undefined' && activeSubPage === 'overview') ? 'active' : '' %>">Overview</a>
                    <a href="/admin/stripe/settings"
                        class="submenu-item <%= (typeof activeSubPage !== 'undefined' && activeSubPage === 'settings') ? 'active' : '' %>">Settings</a>
                    <a href="/admin/stripe/organizers"
                        class="submenu-item <%= (typeof activeSubPage !== 'undefined' && activeSubPage === 'organizers') ? 'active' : '' %>">Organisers</a>
                    <a href="/admin/stripe/transactions"
                        class="submenu-item <%= (typeof activeSubPage !== 'undefined' && activeSubPage === 'transactions') ? 'active' : '' %>">Transactions</a>
                </div>
            </div>
            <a href="/admin/cms" class="nav-item <%= activePage === 'cms' ? 'active' : '' %>" title="Static Pages">
                <i class="fa-solid fa-file-lines"></i>
                <span>Static Pages</span>
            </a>
            <a href="/admin/faqs" class="nav-item <%= activePage === 'faqs' ? 'active' : '' %>" title="Help & FAQs">
                <i class="fa-solid fa-circle-question"></i>
                <span>Help & FAQs</span>
            </a>
            <a href="/admin/inquiries" class="nav-item <%= activePage === 'inquiries' ? 'active' : '' %>"
                title="Inquiries">
                <i class="fa-solid fa-envelope"></i>
                <span>Inquiries</span>
            </a>
            <a href="/admin/settings" class="nav-item <%= activePage === 'settings' ? 'active' : '' %>"
                title="App Settings">
                <i class="fa-solid fa-gears"></i>
                <span>App Settings</span>
            </a>
        </nav>

        <a href="/admin/logout" class="nav-item logoutbtn" title="Logout">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Logout</span>
        </a>

    </aside>

    <div class="main-wrapper">
        <header class="header">


            <div class="header-search">
                <a href="/admin/dashboard" class="logo phone-logo">
                    <img src="/images/logo.svg" alt="HalalBrite">
                    <span>Halal Brite</span>
                </a>
                <button onclick="toggleBar()" class="btn-menu">
                    <svg viewBox="0 0 20 20" class="menu-icon">
                        <path class="line line1" d="M3 5h12"></path>
                        <path class="line line2" d="M3 10h6"></path>
                        <path class="line line3" d="M3 15h12"></path>
                    </svg>
                </button>
                <h2>
                    <%= activePage.charAt(0).toUpperCase() + activePage.slice(1) %> Management
                </h2>
            </div>
            <div class="header-user">
                <!-- Currency Switcher -->
                <div class="btnprice">
                    <i class="fa-solid fa-earth-americas"></i>
                    <select id="currency-switcher">
                        <% (typeof allCurrencies !=='undefined' ? allCurrencies : []).forEach(curr=> { %>
                            <option value="<%= curr.code %>" <%=(typeof currentCurrency !=='undefined' &&
                                currentCurrency.code===curr.code) ? 'selected' : '' %>>
                                <%= curr.code %> (<%= curr.symbol %>)
                            </option>
                            <% }) %>
                    </select>
                </div>

                <span class="nameadi">Admin: <strong>
                        <%= admin.username %>
                    </strong></span>

                <!-- Dark Mode Toggle -->
                <button id="darkModeToggle" class="btn-dark-toggle" title="Toggle Dark Mode">
                    <i class="fa-solid fa-moon" id="darkModeIcon"></i>
                </button>

                <div class="user-avatar">
                    <%= admin.username.charAt(0).toUpperCase() %>
                </div>
            </div>
        </header>

        <main class="content-body">
            <% if (typeof success !=='undefined' && success) { %>
                <div class="badge-success"
                    style="padding: 12px; border-radius: 8px; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 10px; font-weight: 500;">
                    <i class="fa-solid fa-circle-check"></i>
                    <%= success %>
                </div>
                <% } %>

                    <%- body %>
        </main>
    </div>

    <!-- Scripts -->
    <script>

        function toggleBar() {
            document.getElementById("mySidebar").classList.toggle("collapsed");

            // icon animation toggle
            document.querySelector(".menu-icon").classList.toggle("active");
        }
        function toggleSubmenu(id) {
            const menu = document.getElementById(id);
            const isVisible = menu.style.display === 'block';
            menu.style.display = isVisible ? 'none' : 'block';

            // Optional: Rotate arrow
            const arrow = menu.previousElementSibling.querySelector('.submenu-arrow');
            if (arrow) {
                arrow.style.transform = isVisible ? 'rotate(0deg)' : 'rotate(180deg)';
            }
        }

        // Currency Switcher Logic
        document.getElementById('currency-switcher')?.addEventListener('change', function () {
            const selected = this.value;
            // Set cookie for 1 year
            document.cookie = `selected_currency=${selected}; path=/; max-age=${365 * 24 * 60 * 60}`;
            // Refresh to apply changes
            window.location.reload();
        });

        // ===== DARK MODE LOGIC =====
        const htmlEl = document.documentElement;
        const toggleBtn = document.getElementById('darkModeToggle');
        const darkIcon = document.getElementById('darkModeIcon');

        // Load saved theme
        const savedTheme = localStorage.getItem('admin-theme') || 'light';
        htmlEl.setAttribute('data-theme', savedTheme);
        updateDarkIcon(savedTheme);

        toggleBtn?.addEventListener('click', function () {
            const current = htmlEl.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            htmlEl.setAttribute('data-theme', next);
            localStorage.setItem('admin-theme', next);
            updateDarkIcon(next);
        });

        function updateDarkIcon(theme) {
            if (darkIcon) {
                darkIcon.className = theme === 'dark'
                    ? 'fa-solid fa-sun'
                    : 'fa-solid fa-moon';
            }
        }
    </script>
    <script src="/js/stripe-admin.js"></script>
    <%- script %>
</body>

</html>