<div class="card">
    <div class="card-header">
        <h3>User Management</h3>
        <a href="/admin/users/add" class="btn btn-primary btn-sm"><i class="fa-solid fa-plus"></i> Add New User</a>
    </div>
    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>User Info</th>
                    <th>Role</th>
                    <th>Preferences</th>
                    <th>Status</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (users.length===0) { %>
                    <tr>
                        <td colspan="6" class="text-center text-muted" style="padding: 3rem;">No users found.</td>
                    </tr>
                    <% } else { %>
                        <% users.forEach(user=> { %>
                            <tr>
                                <td>
                                    <div class="customer-info">
                                        <span class="customer-name">
                                            <%= user.username %>
                                        </span><br>
                                        <span class="customer-email">
                                            <%= user.email %>
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge" style="background: #eff6ff; color: #1e40af;">
                                        <%= user.roles && user.roles.length> 0 ? user.roles.map(r => r.name).join(', ')
                                            : 'No Role' %>
                                    </span>
                                </td>
                                <td>
                                    <div style="display: flex; gap: 5px;">
                                        <span class="badge"
                                            style="background: <%= user.preferences?.eventUpdates ? '#dcfce7' : '#f3f4f6' %>; color: <%= user.preferences?.eventUpdates ? '#166534' : '#9ca3af' %>;"
                                            title="Event Updates">
                                            <i class="fa-solid fa-calendar-check"></i>
                                        </span>
                                        <span class="badge"
                                            style="background: <%= user.preferences?.promotions ? '#dcfce7' : '#f3f4f6' %>; color: <%= user.preferences?.promotions ? '#166534' : '#9ca3af' %>;"
                                            title="Promotions">
                                            <i class="fa-solid fa-tags"></i>
                                        </span>
                                        <span class="badge"
                                            style="background: <%= user.preferences?.newsletter ? '#dcfce7' : '#f3f4f6' %>; color: <%= user.preferences?.newsletter ? '#166534' : '#9ca3af' %>;"
                                            title="Newsletter">
                                            <i class="fa-solid fa-envelope-open-text"></i>
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <span
                                        class="badge <%= user.status === 'active' ? 'badge-success' : 'badge-danger' %>">
                                        <%= user.status.charAt(0).toUpperCase() + user.status.slice(1) %>
                                    </span>
                                </td>
                                <td class="text-muted">
                                    <%= new Date(user.createdAt).toLocaleDateString() %>
                                </td>
                                <td>
                                    <div style="display: flex; gap: 8px;">
                                        <a href="/admin/users/edit/<%= user._id %>" class="btn btn-sm btn-ghost"
                                            title="Edit User"><i class="fa-solid fa-pen-to-square"></i></a>
                                        <form id="delete-form-<%= user._id %>" action="/admin/users/delete/<%= user._id %>" method="POST">
                                            <button type="button" class="btn btn-sm btn-ghost"
                                                onclick="confirmDelete('<%= user._id %>')"
                                                style="color: var(--danger);" title="Delete"><i
                                                    class="fa-solid fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                                <% } %>
            </tbody>
        </table>
    </div>

    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <div class="card-footer" style="padding: 1.5rem; border-top: 1px solid #f1f5f9;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div class="text-muted text-sm">
                    Showing <%= (typeof currentPage !== 'undefined' ? (currentPage - 1) * 20 + 1 : 1) %> to <%= Math.min((typeof currentPage !== 'undefined' ? currentPage * 20 : 20), (typeof totalRecords !== 'undefined' ? totalRecords : 0)) %> of <%= (typeof totalRecords !== 'undefined' ? totalRecords : 0) %> users
                </div>
                <div style="display: flex; gap: 8px;">
                    <% if (typeof currentPage !== 'undefined' && currentPage > 1) { %>
                        <a href="/admin/users?page=<%= currentPage - 1 %>" class="btn btn-outline btn-sm">Previous</a>
                    <% } %>
                    
                    <% if (typeof currentPage !== 'undefined' && typeof totalPages !== 'undefined') { %>
                        <% for(let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                            <a href="/admin/users?page=<%= i %>" class="btn btn-sm <%= i === currentPage ? 'btn-primary' : 'btn-outline' %>"><%= i %></a>
                        <% } %>
                    <% } %>
                    
                    <% if (typeof currentPage !== 'undefined' && typeof totalPages !== 'undefined' && currentPage < totalPages) { %>
                        <a href="/admin/users?page=<%= currentPage + 1 %>" class="btn btn-outline btn-sm">Next</a>
                    <% } %>
                </div>
            </div>
        </div>
    <% } %>
</div>

<!-- Custom Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 z-[9999] hidden">
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative w-full max-w-md transform overflow-hidden rounded-[2.5rem] bg-white p-8 text-left shadow-2xl transition-all animate-in zoom-in-95 duration-300">
            <button onclick="closeDeleteModal()" class="absolute right-8 top-8 text-slate-400 hover:text-slate-600 transition-colors">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
            <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-red-50 mb-6">
                <i class="fa-solid fa-triangle-exclamation text-3xl text-red-500"></i>
            </div>
            <div class="text-center mb-8 px-4">
                <h3 class="text-2xl font-bold text-slate-900 mb-2">Delete User?</h3>
                <p class="text-slate-500">Are you sure you want to delete this user? This action cannot be undone and all associated data will be removed.</p>
            </div>
            <div class="flex flex-col sm:flex-row gap-3">
                <button onclick="closeDeleteModal()" class="flex-1 px-6 py-4 rounded-2xl bg-slate-100 text-slate-700 font-bold hover:bg-slate-200 transition-all active:scale-[0.98]">
                    Cancel
                </button>
                <button id="confirmDeleteBtn" class="flex-1 px-6 py-4 rounded-2xl bg-red-600 text-white font-bold hover:bg-red-700 shadow-lg shadow-red-200 transition-all active:scale-[0.98]">
                    Yes, Delete
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let formToSubmit = null;
    function confirmDelete(userId) {
        formToSubmit = document.getElementById(`delete-form-${userId}`);
        const modal = document.getElementById('deleteModal');
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }
    function closeDeleteModal() {
        const modal = document.getElementById('deleteModal');
        modal.classList.add('hidden');
        document.body.style.overflow = 'auto';
        formToSubmit = null;
    }
    document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
        if (formToSubmit) {
            formToSubmit.submit();
        }
    });
</script>