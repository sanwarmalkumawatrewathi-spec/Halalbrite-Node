<%
  const filtersObj = typeof filters !== 'undefined' ? filters : { search: '', role: '', status: '', joinedFrom: '', joinedTo: '' };
  const rolesArr = typeof roles !== 'undefined' ? roles : [];
  const queryStr = typeof queryString !== 'undefined' ? queryString : '';
%>
<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
        <h3>User Management</h3>
        <div style="display: flex; gap: 8px;">
            <a href="/admin/users/export<%= queryStr ? '?' + queryStr : '' %>" class="btn btn-outline btn-sm">
                <i class="fa-solid fa-file-csv"></i> Export to CSV
            </a>
            <a href="/admin/users/add" class="btn btn-primary btn-sm"><i class="fa-solid fa-plus"></i> Add New User</a>
        </div>
    </div>
    
    <!-- Premium Search & Filter Bar -->
    <form method="GET" action="/admin/users" class="bg-[var(--card-bg)] border-b border-[var(--border-color)] p-4 sm:p-6">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-end">
            <!-- Search bar -->
            <div class="md:col-span-4">
                <label class="block text-xs font-bold uppercase tracking-wider text-[var(--text-muted)] mb-2">Search User Info</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-[var(--text-muted)]">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </span>
                    <input type="text" name="search" value="<%= filtersObj.search %>" placeholder="Search by name or email..." class="w-full pl-9 pr-4 py-2 rounded-lg border border-[var(--border-color)] focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-[var(--primary)] text-sm bg-[var(--card-bg)] transition-all text-[var(--text-main)]" />
                </div>
            </div>

            <!-- Role Filter -->
            <div class="md:col-span-2">
                <label class="block text-xs font-bold uppercase tracking-wider text-[var(--text-muted)] mb-2">Role</label>
                <select name="role" class="w-full px-3 py-2 rounded-lg border border-[var(--border-color)] focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-[var(--primary)] text-sm bg-[var(--card-bg)] transition-all text-[var(--text-main)] cursor-pointer">
                    <option value="" class="bg-[var(--card-bg)] text-[var(--text-main)]">All Roles</option>
                    <% rolesArr.forEach(role => { %>
                        <option value="<%= role._id %>" <%= filtersObj.role === role._id.toString() ? 'selected' : '' %> class="bg-[var(--card-bg)] text-[var(--text-main)]"><%= role.name %></option>
                    <% }) %>
                </select>
            </div>

            <!-- Status Filter -->
            <div class="md:col-span-2">
                <label class="block text-xs font-bold uppercase tracking-wider text-[var(--text-muted)] mb-2">Status</label>
                <select name="status" class="w-full px-3 py-2 rounded-lg border border-[var(--border-color)] focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-[var(--primary)] text-sm bg-[var(--card-bg)] transition-all text-[var(--text-main)] cursor-pointer">
                    <option value="" class="bg-[var(--card-bg)] text-[var(--text-main)]">All Statuses</option>
                    <option value="active" <%= filtersObj.status === 'active' ? 'selected' : '' %> class="bg-[var(--card-bg)] text-[var(--text-main)]">Active</option>
                    <option value="inactive" <%= filtersObj.status === 'inactive' ? 'selected' : '' %> class="bg-[var(--card-bg)] text-[var(--text-main)]">Inactive</option>
                    <option value="suspended" <%= filtersObj.status === 'suspended' ? 'selected' : '' %> class="bg-[var(--card-bg)] text-[var(--text-main)]">Suspended</option>
                </select>
            </div>

            <!-- Joined From Filter -->
            <div class="md:col-span-2">
                <label class="block text-xs font-bold uppercase tracking-wider text-[var(--text-muted)] mb-2">Joined From</label>
                <input type="date" name="joinedFrom" value="<%= filtersObj.joinedFrom %>" class="w-full px-3 py-2 rounded-lg border border-[var(--border-color)] focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-[var(--primary)] text-sm bg-[var(--card-bg)] transition-all text-[var(--text-main)]" />
            </div>

            <!-- Joined To Filter -->
            <div class="md:col-span-2">
                <label class="block text-xs font-bold uppercase tracking-wider text-[var(--text-muted)] mb-2">Joined To</label>
                <input type="date" name="joinedTo" value="<%= filtersObj.joinedTo %>" class="w-full px-3 py-2 rounded-lg border border-[var(--border-color)] focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-[var(--primary)] text-sm bg-[var(--card-bg)] transition-all text-[var(--text-main)]" />
            </div>
        </div>
        
        <div class="flex flex-wrap gap-2 mt-4 justify-end">
            <% if (filtersObj.search || filtersObj.role || filtersObj.status || filtersObj.joinedFrom || filtersObj.joinedTo) { %>
                <a href="/admin/users" class="px-4 py-2 rounded-lg bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-[var(--text-main)] font-semibold text-sm transition-all flex items-center gap-2">
                    <i class="fa-solid fa-rotate-left"></i> Reset
                </a>
            <% } %>
            <button type="submit" class="px-5 py-2 rounded-lg bg-primary hover:bg-primary/95 text-white font-semibold text-sm transition-all shadow-md shadow-primary/10 flex items-center gap-2">
                <i class="fa-solid fa-filter"></i> Apply Filters
            </button>
        </div>
    </form>

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>User Info</th>
                    <th>Role</th>
                    <th>Preferences</th>
                    <th>Status</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (users.length===0) { %>
                    <tr>
                        <td colspan="6" class="text-center text-muted" style="padding: 3rem;">No users found.</td>
                    </tr>
                    <% } else { %>
                        <% users.forEach(user=> { %>
                            <tr>
                                <td>
                                    <div class="customer-info">
                                        <span class="customer-name">
                                            <%= user.username %>
                                        </span><br>
                                        <span class="customer-email">
                                            <%= user.email %>
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge" style="background: #eff6ff; color: #1e40af;">
                                        <%= user.roles && user.roles.length> 0 ? user.roles.map(r => r.name).join(', ')
                                            : 'No Role' %>
                                    </span>
                                </td>
                                <td>
                                    <div style="display: flex; gap: 5px;">
                                        <span class="badge"
                                            style="background: <%= user.preferences?.eventUpdates ? '#dcfce7' : '#f3f4f6' %>; color: <%= user.preferences?.eventUpdates ? '#166534' : '#9ca3af' %>;"
                                            title="Event Updates">
                                            <i class="fa-solid fa-calendar-check"></i>
                                        </span>
                                        <span class="badge"
                                            style="background: <%= user.preferences?.promotions ? '#dcfce7' : '#f3f4f6' %>; color: <%= user.preferences?.promotions ? '#166534' : '#9ca3af' %>;"
                                            title="Promotions">
                                            <i class="fa-solid fa-tags"></i>
                                        </span>
                                        <span class="badge"
                                            style="background: <%= user.preferences?.newsletter ? '#dcfce7' : '#f3f4f6' %>; color: <%= user.preferences?.newsletter ? '#166534' : '#9ca3af' %>;"
                                            title="Newsletter">
                                            <i class="fa-solid fa-envelope-open-text"></i>
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    <span
                                        class="badge <%= user.status === 'active' ? 'badge-success' : 'badge-danger' %>">
                                        <%= user.status.charAt(0).toUpperCase() + user.status.slice(1) %>
                                    </span>
                                </td>
                                <td class="text-muted">
                                    <%= new Date(user.createdAt).toLocaleDateString() %>
                                </td>
                                <td>
                                    <div style="display: flex; gap: 8px;">
                                        <a href="/admin/users/edit/<%= user._id %>" class="btn btn-sm btn-ghost"
                                            title="Edit User"><i class="fa-solid fa-pen-to-square"></i></a>
                                        <form id="delete-form-<%= user._id %>" action="/admin/users/delete/<%= user._id %>" method="POST">
                                            <button type="button" class="btn btn-sm btn-ghost"
                                                onclick="confirmDelete('<%= user._id %>')"
                                                style="color: var(--danger);" title="Delete"><i
                                                    class="fa-solid fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                                <% } %>
            </tbody>
        </table>
    </div>

    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <div class="card-footer" style="padding: 1.5rem; border-top: 1px solid var(--border-color);">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div class="text-muted text-sm">
                    Showing <%= (typeof currentPage !== 'undefined' ? (currentPage - 1) * 20 + 1 : 1) %> to <%= Math.min((typeof currentPage !== 'undefined' ? currentPage * 20 : 20), (typeof totalRecords !== 'undefined' ? totalRecords : 0)) %> of <%= (typeof totalRecords !== 'undefined' ? totalRecords : 0) %> users
                </div>
                <div style="display: flex; gap: 8px;">
                    <% if (typeof currentPage !== 'undefined' && currentPage > 1) { %>
                        <a href="/admin/users?page=<%= currentPage - 1 %><%= queryStr ? '&' + queryStr : '' %>" class="btn btn-outline btn-sm">Previous</a>
                    <% } %>
                    
                    <% if (typeof currentPage !== 'undefined' && typeof totalPages !== 'undefined') { %>
                        <% for(let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                            <a href="/admin/users?page=<%= i %><%= queryStr ? '&' + queryStr : '' %>" class="btn btn-sm <%= i === currentPage ? 'btn-primary' : 'btn-outline' %>"><%= i %></a>
                        <% } %>
                    <% } %>
                    
                    <% if (typeof currentPage !== 'undefined' && typeof totalPages !== 'undefined' && currentPage < totalPages) { %>
                        <a href="/admin/users?page=<%= currentPage + 1 %><%= queryStr ? '&' + queryStr : '' %>" class="btn btn-outline btn-sm">Next</a>
                    <% } %>
                </div>
            </div>
        </div>
    <% } %>
</div>

<!-- Custom Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 z-[9999] hidden">
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative w-full max-w-md transform overflow-hidden rounded-[2.5rem] bg-white p-8 text-left shadow-2xl transition-all animate-in zoom-in-95 duration-300">
            <button onclick="closeDeleteModal()" class="absolute right-8 top-8 text-slate-400 hover:text-slate-600 transition-colors">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
            <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-red-50 mb-6">
                <i class="fa-solid fa-triangle-exclamation text-3xl text-red-500"></i>
            </div>
            <div class="text-center mb-8 px-4">
                <h3 class="text-2xl font-bold text-slate-900 mb-2">Delete User?</h3>
                <p class="text-slate-500">Are you sure you want to delete this user? This action cannot be undone and all associated data will be removed.</p>
            </div>
            <div class="flex flex-col sm:flex-row gap-3">
                <button onclick="closeDeleteModal()" class="flex-1 px-6 py-4 rounded-2xl bg-slate-100 text-slate-700 font-bold hover:bg-slate-200 transition-all active:scale-[0.98]">
                    Cancel
                </button>
                <button id="confirmDeleteBtn" class="flex-1 px-6 py-4 rounded-2xl bg-red-600 text-white font-bold hover:bg-red-700 shadow-lg shadow-red-200 transition-all active:scale-[0.98]">
                    Yes, Delete
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let formToSubmit = null;
    function confirmDelete(userId) {
        formToSubmit = document.getElementById(`delete-form-${userId}`);
        const modal = document.getElementById('deleteModal');
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }
    function closeDeleteModal() {
        const modal = document.getElementById('deleteModal');
        modal.classList.add('hidden');
        document.body.style.overflow = 'auto';
        formToSubmit = null;
    }
    document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
        if (formToSubmit) {
            formToSubmit.submit();
        }
    });
</script>