<%- contentFor('style') %>
<style>
    .view-container { max-width: 1100px; margin: 0 auto; }
    .event-hero { 
        height: 350px; 
        border-radius: 24px; 
        overflow: hidden; 
        position: relative; 
        margin-bottom: 2rem;
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
    }
    .hero-img { width: 100%; height: 100%; object-fit: cover; }
    .hero-overlay {
        position: absolute; bottom: 0; left: 0; right: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
        padding: 40px; color: white;
    }
    .hero-title { font-size: 2.25rem; font-weight: 800; margin: 0; }
    .hero-badge { 
        display: inline-block; padding: 6px 16px; border-radius: 9999px; 
        background: rgba(227, 30, 36, 0.9); font-weight: 700; font-size: 0.8rem;
        text-transform: uppercase; margin-bottom: 12px;
    }
    .content-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; }
    .info-card { 
        background: white; border-radius: 24px; padding: 32px; 
        border: 1px solid #f3f4f6; box-shadow: 0 1px 3px 0 rgba(0,0,0,0.05);
        margin-bottom: 2rem;
    }
    .card-title { color: #991b1b; font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 10px; }
    .stats-card { background: #fef2f2; border: 1px solid #fee2e2; border-radius: 24px; padding: 24px; }
    .stat-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #fee2e2; }
    .stat-item:last-child { border-bottom: none; }
    .stat-label { color: #991b1b; font-weight: 600; font-size: 0.9rem; }
    .stat-value { font-weight: 700; color: #1c1917; }
    .action-bar { display: flex; gap: 12px; margin-bottom: 2rem; justify-content: flex-end; }
    .btn-premium { padding: 10px 20px; border-radius: 9999px; font-weight: 600; font-size: 0.875rem; text-decoration: none; display: flex; align-items: center; gap: 8px; transition: all 0.2s; }
    .btn-edit { background: #991b1b; color: white; }
    .btn-edit:hover { background: #7f1d1d; }
    .btn-sales { background: #1c1917; color: white; }
    .btn-sales:hover { background: #000; }
    .btn-back { background: #f3f4f6; color: #4b5563; }
    .btn-back:hover { background: #e5e7eb; }
</style>

<%- contentFor('body') %>
<div class="view-container">
    <div class="action-bar">
        <a href="/admin/events" class="btn-premium btn-back"><i class="fa-solid fa-arrow-left"></i> Back</a>
        <a href="/admin/events/edit/<%= event._id %>" class="btn-premium btn-edit"><i class="fa-solid fa-pen"></i> Edit Event</a>
        <a href="/admin/orders?event=<%= event._id %>" class="btn-premium btn-sales"><i class="fa-solid fa-receipt"></i> View Sales</a>
    </div>

    <div class="event-hero">
        <img src="<%= event.banner || '/images/default-banner.jpg' %>" class="hero-img">
        <div class="hero-overlay">
            <span class="hero-badge"><%= event.category?.name || 'Event' %></span>
            <h1 class="hero-title"><%= event.title %></h1>
        </div>
    </div>

    <div class="content-grid">
        <div class="left-col">
            <div class="info-card">
                <h3 class="card-title"><i class="fa-solid fa-align-left"></i> Description</h3>
                <div class="description-text" style="line-height: 1.8; color: #4b5563;">
                    <%- event.description %>
                </div>
            </div>

            <div class="info-card">
                <h3 class="card-title"><i class="fa-solid fa-ticket"></i> Ticket Types</h3>
                <div class="table-responsive">
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="text-align: left; border-bottom: 2px solid #f3f4f6;">
                                <th style="padding: 16px; font-size: 0.8rem; text-transform: uppercase; color: #94a3b8;">Type</th>
                                <th style="padding: 16px; font-size: 0.8rem; text-transform: uppercase; color: #94a3b8;">Price</th>
                                <th style="padding: 16px; font-size: 0.8rem; text-transform: uppercase; color: #94a3b8;">Quantity</th>
                                <th style="padding: 16px; font-size: 0.8rem; text-transform: uppercase; color: #94a3b8;">Sales</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% event.ticketTypes.forEach(ticket => { %>
                                <tr style="border-bottom: 1px solid #f3f4f6;">
                                    <td style="padding: 16px;">
                                        <div style="font-weight: 700; color: #1c1917;"><%= ticket.name %></div>
                                        <div style="font-size: 0.75rem; color: #64748b;"><%- ticket.description || 'No description' %></div>
                                    </td>
                                    <td style="padding: 16px; font-weight: 600; color: #991b1b;">
                                        <%= ticket.price === 0 ? 'Free' : formatPrice(ticket.price) %>
                                    </td>
                                    <td style="padding: 16px; color: #4b5563;"><%= ticket.quantity %></td>
                                    <td style="padding: 16px;">
                                        <span style="font-size: 0.8rem; background: #f1f5f9; padding: 4px 10px; border-radius: 9999px; color: #475569;">
                                            Ends <%= new Date(ticket.saleEnd).toLocaleDateString() %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="right-col">
            <div class="stats-card">
                <h3 class="card-title" style="margin-bottom: 1rem;"><i class="fa-solid fa-chart-line"></i> Quick Stats</h3>
                <div class="stat-item">
                    <span class="stat-label">Total Bookings</span>
                    <span class="stat-value"><%= bookingsCount %></span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">Status</span>
                    <span class="stat-value" style="text-transform: capitalize;"><%= event.status %></span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">Event Type</span>
                    <span class="stat-value"><%= event.eventType %></span>
                </div>
            </div>

            <div class="info-card" style="margin-top: 1.5rem; padding: 24px;">
                <h3 class="card-title" style="font-size: 1rem;"><i class="fa-solid fa-location-dot"></i> Logistics</h3>
                <div style="font-size: 0.9rem; color: #4b5563; space-y-4">
                    <div style="margin-bottom: 12px; display: flex; gap: 10px;">
                        <i class="fa-regular fa-calendar-check" style="color: #991b1b; margin-top: 3px;"></i>
                        <div>
                            <strong><%= new Date(event.startDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %></strong><br>
                            <span style="font-size: 0.8rem;"><%= event.startTime %> - <%= event.endTime %></span>
                        </div>
                    </div>
                    <% if (event.location && event.location.venueName) { %>
                        <div style="display: flex; gap: 10px;">
                            <i class="fa-solid fa-map-pin" style="color: #991b1b; margin-top: 3px;"></i>
                            <div>
                                <strong><%= event.location.venueName %></strong><br>
                                <span style="font-size: 0.8rem;"><%= event.location.address %>, <%= event.location.city %></span>
                            </div>
                        </div>
                    <% } %>
                    <hr style="border: 0; border-top: 1px solid #f3f4f6; margin: 16px 0;">
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <div style="width: 32px; height: 32px; border-radius: 50%; background: #f3f4f6; display: flex; align-items: center; justify-content: center; color: #991b1b;">
                            <i class="fa-solid fa-user-tie"></i>
                        </div>
                        <div>
                            <span style="font-size: 0.75rem; color: #94a3b8; display: block;">Organizer</span>
                            <strong style="font-size: 0.85rem;"><%= event.organizer ? event.organizer.username : 'Admin' %></strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
