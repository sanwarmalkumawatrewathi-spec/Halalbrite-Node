<div class="card" style="margin-bottom: 24px;">
    <div class="card-header">
        <div>
            <h3 style="margin: 0;">Email Delivery Logs</h3>
            <span class="text-muted" style="display: block; margin-top: 4px; font-size: 0.875rem;">History of outgoing platform notifications</span>
        </div>
    </div>
</div>

<div class="form-container">
    <div class="form-section-card">
        <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>Timestamp</th>
                    <th>Recipient</th>
                    <th>Role</th>
                    <th>Subject</th>
                    <th>Booking Ref</th>
                    <th>Status</th>
                    <th>Details / Failure Reason</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (logs.length === 0) { %>
                    <tr>
                        <td colspan="8" class="text-center text-muted">No email logs found.</td>
                    </tr>
                <% } else { %>
                    <% logs.forEach(log => { %>
                        <tr>
                            <td>
                                <%= new Date(log.createdAt).toLocaleString('en-GB', { 
                                    day: '2-digit', month: '2-digit', year: 'numeric',
                                    hour: '2-digit', minute: '2-digit' 
                                }) %>
                            </td>
                            <td>
                                <div class="customer-info">
                                    <span class="customer-name"><%= log.recipient %></span>
                                </div>
                            </td>
                            <td>
                                <span class="badge badge-premium <%= log.role === 'admin' ? 'badge-primary' : (log.role === 'organizer' ? 'badge-warning' : 'badge-info') %>">
                                    <%= log.role %>
                                </span>
                            </td>
                            <td title="<%= log.subject %>">
                                <%= log.subject.substring(0, 40) %><%= log.subject.length > 40 ? '...' : '' %>
                            </td>
                            <td>
                                <% if (log.booking_id) { %>
                                    <a href="/admin/orders/view/<%= log.booking_id._id %>">
                                        <%= log.booking_id.booking_reference %>
                                    </a>
                                <% } else { %>
                                    <span class="text-muted">-</span>
                                <% } %>
                            </td>
                            <td>
                                <% if (log.status === 'sent') { %>
                                    <span class="badge badge-premium badge-success"><i class="fa-solid fa-check"></i> Sent</span>
                                <% } else { %>
                                    <span class="badge badge-premium badge-danger">
                                        <i class="fa-solid fa-xmark"></i> Failed
                                    </span>
                                <% } %>
                            </td>
                            <td>
                                <% if (log.status === 'sent') { %>
                                    <span class="text-success" style="font-size: 11px; font-family: monospace; display: block; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= log.messageId %>">
                                        <%= log.messageId || 'Success' %>
                                    </span>
                                <% } else { %>
                                    <span class="text-danger" style="font-size: 11px; font-weight: 500; word-break: break-word; display: block; max-width: 250px; line-height: 1.3;">
                                        <%= log.error || 'Connection timed out / Auth failed' %>
                                    </span>
                                <% } %>
                            </td>
                            <td>
                                <form action="/admin/email-logs/delete/<%= log._id %>" method="POST" onsubmit="return confirm('Delete this log entry?')">
                                    <button type="submit" class="btn btn-sm btn-ghost" style="color: var(--danger);">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>

    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <div class="card-footer" style="padding: 1.5rem; border-top: 1px solid #f1f5f9;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div class="text-muted text-sm">
                    Showing <%= (typeof currentPage !== 'undefined' ? (currentPage - 1) * 20 + 1 : 1) %> to <%= Math.min((typeof currentPage !== 'undefined' ? currentPage * 20 : 20), (typeof totalRecords !== 'undefined' ? totalRecords : 0)) %> of <%= (typeof totalRecords !== 'undefined' ? totalRecords : 0) %> logs
                </div>
                <div style="display: flex; gap: 8px;">
                    <% if (typeof currentPage !== 'undefined' && currentPage > 1) { %>
                        <a href="/admin/email-logs?page=<%= currentPage - 1 %>" class="btn btn-outline btn-sm">Previous</a>
                    <% } %>
                    
                    <% if (typeof currentPage !== 'undefined' && typeof totalPages !== 'undefined') { %>
                        <% for(let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                            <a href="/admin/email-logs?page=<%= i %>" class="btn btn-sm <%= i === currentPage ? 'btn-primary' : 'btn-outline' %>"><%= i %></a>
                        <% } %>
                    <% } %>
                    
                    <% if (typeof currentPage !== 'undefined' && typeof totalPages !== 'undefined' && currentPage < totalPages) { %>
                        <a href="/admin/email-logs?page=<%= currentPage + 1 %>" class="btn btn-outline btn-sm">Next</a>
                    <% } %>
                </div>
            </div>
        </div>
    <% } %>
    </div>
</div>
