<%
  const filtersObj = typeof filters !== 'undefined' ? filters : { search: '', category: '', organizer: '', organizerEmail: '', status: '', startDateFrom: '', startDateTo: '' };
  const categoriesArr = typeof categories !== 'undefined' ? categories : [];
  const organizersArr = typeof organizers !== 'undefined' ? organizers : [];
  const queryStr = typeof queryString !== 'undefined' ? queryString : '';
%>
<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
        <h3>Global Event Management</h3>
        <div style="display: flex; gap: 8px;">
            <a href="/admin/events/export<%= queryStr ? '?' + queryStr : '' %>" class="btn btn-outline btn-sm">
                <i class="fa-solid fa-file-csv"></i> Export to CSV
            </a>
            <a href="/admin/events/add" class="btn btn-primary btn-sm"><i class="fa-solid fa-plus"></i> Add New Event</a>
        </div>
    </div>
    
    <!-- Premium Search & Filter Bar -->
    <form method="GET" action="/admin/events" class="bg-[var(--card-bg)] border-b border-[var(--border-color)] p-4 sm:p-6">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-end">
            <!-- Search bar -->
            <div class="md:col-span-3">
                <label class="block text-xs font-bold uppercase tracking-wider text-[var(--text-muted)] mb-2">Search Event Info</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-[var(--text-muted)]">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </span>
                    <input type="text" name="search" value="<%= filtersObj.search %>" placeholder="Search by title or organizer..." class="w-full pl-9 pr-4 py-2 rounded-lg border border-[var(--border-color)] focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-[var(--primary)] text-sm bg-[var(--card-bg)] transition-all text-[var(--text-main)]" />
                </div>
            </div>

            <!-- Organizer Filter -->
            <div class="md:col-span-2">
                <label class="block text-xs font-bold uppercase tracking-wider text-[var(--text-muted)] mb-2">Organizer</label>
                <select name="organizer" class="w-full px-3 py-2 rounded-lg border border-[var(--border-color)] focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-[var(--primary)] text-sm bg-[var(--card-bg)] transition-all text-[var(--text-main)] cursor-pointer">
                    <option value="" class="bg-[var(--card-bg)] text-[var(--text-main)]">All Organizers</option>
                    <% organizersArr.forEach(org => { %>
                        <option value="<%= org._id %>" <%= filtersObj.organizer === org._id.toString() ? 'selected' : '' %> class="bg-[var(--card-bg)] text-[var(--text-main)]"><%= org.username %></option>
                    <% }) %>
                </select>
            </div>

            <!-- Organizer Email Filter -->
            <div class="md:col-span-2">
                <label class="block text-xs font-bold uppercase tracking-wider text-[var(--text-muted)] mb-2">Organizer Email</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-[var(--text-muted)]">
                        <i class="fa-solid fa-envelope"></i>
                    </span>
                    <input type="text" name="organizerEmail" value="<%= filtersObj.organizerEmail %>" placeholder="Search by email..." class="w-full pl-9 pr-4 py-2 rounded-lg border border-[var(--border-color)] focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-[var(--primary)] text-sm bg-[var(--card-bg)] transition-all text-[var(--text-main)]" />
                </div>
            </div>

            <!-- Category Filter -->
            <div class="md:col-span-2">
                <label class="block text-xs font-bold uppercase tracking-wider text-[var(--text-muted)] mb-2">Category</label>
                <select name="category" class="w-full px-3 py-2 rounded-lg border border-[var(--border-color)] focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-[var(--primary)] text-sm bg-[var(--card-bg)] transition-all text-[var(--text-main)] cursor-pointer">
                    <option value="" class="bg-[var(--card-bg)] text-[var(--text-main)]">All Categories</option>
                    <% categoriesArr.forEach(cat => { %>
                        <option value="<%= cat._id %>" <%= filtersObj.category === cat._id.toString() ? 'selected' : '' %> class="bg-[var(--card-bg)] text-[var(--text-main)]"><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>

            <!-- Status Filter -->
            <div class="md:col-span-1">
                <label class="block text-xs font-bold uppercase tracking-wider text-[var(--text-muted)] mb-2">Status</label>
                <select name="status" class="w-full px-3 py-2 rounded-lg border border-[var(--border-color)] focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-[var(--primary)] text-sm bg-[var(--card-bg)] transition-all text-[var(--text-main)] cursor-pointer">
                    <option value="" class="bg-[var(--card-bg)] text-[var(--text-main)]">All Statuses</option>
                    <option value="published" <%= filtersObj.status === 'published' ? 'selected' : '' %> class="bg-[var(--card-bg)] text-[var(--text-main)]">Published</option>
                    <option value="draft" <%= filtersObj.status === 'draft' ? 'selected' : '' %> class="bg-[var(--card-bg)] text-[var(--text-main)]">Draft</option>
                    <option value="cancelled" <%= filtersObj.status === 'cancelled' ? 'selected' : '' %> class="bg-[var(--card-bg)] text-[var(--text-main)]">Cancelled</option>
                    <option value="completed" <%= filtersObj.status === 'completed' ? 'selected' : '' %> class="bg-[var(--card-bg)] text-[var(--text-main)]">Completed</option>
                </select>
            </div>

            <!-- Start Date From Filter -->
            <div class="md:col-span-1">
                <label class="block text-xs font-bold uppercase tracking-wider text-[var(--text-muted)] mb-2">Date From</label>
                <input type="date" name="startDateFrom" value="<%= filtersObj.startDateFrom %>" class="w-full px-3 py-2 rounded-lg border border-[var(--border-color)] focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-[var(--primary)] text-sm bg-[var(--card-bg)] transition-all text-[var(--text-main)]" />
            </div>

            <!-- Start Date To Filter -->
            <div class="md:col-span-1">
                <label class="block text-xs font-bold uppercase tracking-wider text-[var(--text-muted)] mb-2">Date To</label>
                <input type="date" name="startDateTo" value="<%= filtersObj.startDateTo %>" class="w-full px-3 py-2 rounded-lg border border-[var(--border-color)] focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-[var(--primary)] text-sm bg-[var(--card-bg)] transition-all text-[var(--text-main)]" />
            </div>
        </div>
        
        <div class="flex flex-wrap gap-2 mt-4 justify-end">
            <% if (filtersObj.search || filtersObj.category || filtersObj.organizer || filtersObj.organizerEmail || filtersObj.status || filtersObj.startDateFrom || filtersObj.startDateTo) { %>
                <a href="/admin/events" class="px-4 py-2 rounded-lg bg-slate-100 hover:bg-slate-200 dark:bg-slate-800 dark:hover:bg-slate-700 text-[var(--text-main)] font-semibold text-sm transition-all flex items-center gap-2">
                    <i class="fa-solid fa-rotate-left"></i> Reset
                </a>
            <% } %>
            <button type="submit" class="px-5 py-2 rounded-lg bg-primary hover:bg-primary/95 text-white font-semibold text-sm transition-all shadow-md shadow-primary/10 flex items-center gap-2">
                <i class="fa-solid fa-filter"></i> Apply Filters
            </button>
        </div>
    </form>

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>Event Details</th>
                    <th>Organizer</th>
                    <th>Account Email</th>
                    <th>Category</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (events.length===0) { %>
                    <tr>
                        <td colspan="7" class="text-center text-muted" style="padding: 3rem;">No events found.</td>
                    </tr>
                    <% } else { %>
                        <% events.forEach(event=> { %>
                            <tr>
                                <td>
                                    <div style="display: flex; gap: 12px; align-items: center;">
                                        <img src="<%= event.thumbnail %>"
                                            style="width: 50px; height: 35px; border-radius: 6px; object-fit: cover; background: #f1f5f9;">
                                        <div>
                                            <span class="customer-name">
                                                <%= event.title %>
                                            </span><br>
                                            <span class="customer-email">
                                                <%= event.price===0 ? 'Free' : 'From ' + formatPrice(event.price) %>
                                            </span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="customer-name">
                                        <%= event.organizer ? event.organizer.username : 'Deleted' %>
                                    </span>
                                </td>
                                <td>
                                    <span class="customer-email">
                                        <%= event.organizer ? event.organizer.email : '-' %>
                                    </span>
                                </td>
                                <td>
                                    <span class="badge" style="background: #fff7ed; color: #9a3412;">
                                        <%= event.category ? event.category.name : 'Uncategorized' %>
                                    </span>
                                </td>
                                <td class="text-muted">
                                    <%= new Date(event.startDate).toLocaleDateString() %>
                                </td>
                                <td>
                                    <span
                                        class="badge <%= event.status === 'published' ? 'badge-success' : 'badge-warning' %>">
                                        <%= event.status.charAt(0).toUpperCase() + event.status.slice(1) %>
                                    </span>
                                </td>
                                <td>
                                    <div style="display: flex; gap: 5px;">
                                        <a href="/admin/events/view/<%= event._id %>" class="btn btn-sm btn-ghost"
                                            title="View"><i class="fa-solid fa-eye"></i></a>
                                        <a href="/admin/events/edit/<%= event._id %>" class="btn btn-sm btn-ghost"
                                            title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                                        <form action="/admin/events/delete/<%= event._id %>" method="POST"
                                            onsubmit="return confirm('Delete event?')">
                                            <button type="submit" class="btn btn-sm btn-ghost"
                                                style="color: var(--danger);"><i class="fa-solid fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                                <% } %>
            </tbody>
        </table>
    </div>

    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <div class="card-footer" style="padding: 1.5rem; border-top: 1px solid var(--border-color);">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div class="text-muted text-sm">
                    Showing <%= (typeof currentPage !== 'undefined' ? (currentPage - 1) * 20 + 1 : 1) %> to <%= Math.min((typeof currentPage !== 'undefined' ? currentPage * 20 : 20), (typeof totalRecords !== 'undefined' ? totalRecords : 0)) %> of <%= (typeof totalRecords !== 'undefined' ? totalRecords : 0) %> events
                </div>
                <div style="display: flex; gap: 8px;">
                    <% if (typeof currentPage !== 'undefined' && currentPage > 1) { %>
                        <a href="/admin/events?page=<%= currentPage - 1 %><%= queryStr ? '&' + queryStr : '' %>" class="btn btn-outline btn-sm">Previous</a>
                    <% } %>
                    
                    <% if (typeof currentPage !== 'undefined' && typeof totalPages !== 'undefined') { %>
                        <% for(let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
                            <a href="/admin/events?page=<%= i %><%= queryStr ? '&' + queryStr : '' %>" class="btn btn-sm <%= i === currentPage ? 'btn-primary' : 'btn-outline' %>"><%= i %></a>
                        <% } %>
                    <% } %>
                    
                    <% if (typeof currentPage !== 'undefined' && typeof totalPages !== 'undefined' && currentPage < totalPages) { %>
                        <a href="/admin/events?page=<%= currentPage + 1 %><%= queryStr ? '&' + queryStr : '' %>" class="btn btn-outline btn-sm">Next</a>
                    <% } %>
                </div>
            </div>
        </div>
    <% } %>
</div>