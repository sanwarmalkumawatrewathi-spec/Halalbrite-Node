<div class="card" style="margin-bottom: 24px;">
    <div class="card-header">
        <h3 style="margin: 0;">Customer Inquiries</h3>
    </div>
</div>

<div class="form-container">
    <div class="form-section-card">
        <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>Customer</th>
                    <th>Subject</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (inquiries.length === 0) { %>
                    <tr><td colspan="5" class="text-center text-muted" style="padding: 3rem;">No inquiries found.</td></tr>
                <% } else { %>
                    <% inquiries.forEach(inq => { %>
                        <tr id="inquiry-row-<%= inq._id %>">
                            <td>
                                <div class="customer-info">
                                    <span class="customer-name"><%= inq.fullName || 'No Name' %></span><br>
                                    <span class="customer-email"><%= inq.email || 'No Email' %></span>
                                </div>
                            </td>
                            <td>
                                <span class="event-title"><%= inq.subject || 'No Subject' %></span>
                            </td>
                            <td>
                                <span id="badge-<%= inq._id %>" class="badge <%= inq.status === 'new' ? 'badge-warning' : 'badge-success' %>">
                                    <%= (inq.status || 'new').toUpperCase() %>
                                </span>
                            </td>
                            <td class="text-muted"><%= inq.createdAt ? new Date(inq.createdAt).toLocaleDateString() : 'N/A' %></td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <!-- Hidden message content to avoid JS character escaping issues -->
                                    <div id="msg-<%= inq._id %>" style="display:none;"><%= inq.message %></div>
                                    <button class="btn btn-sm btn-ghost" title="View Message" 
                                        data-name="<%= inq.fullName %>"
                                        data-email="<%= inq.email %>"
                                        data-subject="<%= inq.subject %>"
                                        onclick="viewInquiry('<%= inq._id %>', this)">
                                        <i class="fa-solid fa-envelope-open"></i>
                                    </button>
                                    <form action="/admin/inquiries/delete/<%= inq._id %>" method="POST" onsubmit="return confirm('Delete inquiry?')">
                                        <button type="submit" class="btn btn-sm btn-ghost" style="color: var(--danger);"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
    </div>
</div>

<!-- Inquiry Modal -->
<div id="inquiryModal" class="modal-backdrop" style="display: none;">
    <div class="modal-premium">
        <button onclick="closeModal()" style="position: absolute; top: 1.5rem; right: 1.5rem; border: none; background: none; font-size: 1.5rem; cursor: pointer; color: #64748b;">&times;</button>
        
        <h3 id="modalSubject" class="form-title" style="margin-bottom: 0.5rem;"></h3>
        <div style="margin-bottom: 1.5rem; font-size: 0.875rem; color: #64748b;">
            From: <strong id="modalName" style="color: var(--form-text);"></strong> (<span id="modalEmail"></span>)
        </div>
        
        <hr style="border: none; border-top: 1px solid var(--form-border); margin-bottom: 1.5rem;">
        
        <div id="modalMessage" style="white-space: pre-wrap; line-height: 1.8; color: var(--form-text); min-height: 120px; font-size: 1rem;"></div>
        
        <div style="margin-top: 2.5rem; text-align: right;">
            <button onclick="closeModal()" class="form-btn-cancel">Close</button>
        </div>
    </div>
</div>

<script>
    function viewInquiry(id, btn) {
        const name = btn.getAttribute('data-name');
        const email = btn.getAttribute('data-email');
        const subject = btn.getAttribute('data-subject');

        document.getElementById('modalName').textContent = name || 'No Name';
        document.getElementById('modalEmail').textContent = email || 'No Email';
        document.getElementById('modalSubject').textContent = subject || 'No Subject';
        
        // Get message from hidden div to handle special characters correctly
        const msgDiv = document.getElementById('msg-' + id);
        const message = msgDiv ? msgDiv.textContent : 'No message content.';
        document.getElementById('modalMessage').textContent = message;
        
        const modal = document.getElementById('inquiryModal');
        modal.style.display = 'flex';

        // Mark as read in backend
        const badge = document.getElementById('badge-' + id);
        if (badge && (badge.classList.contains('badge-warning') || badge.innerText.trim().toLowerCase() === 'new')) {
            fetch('/admin/inquiries/read/' + id, { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        badge.classList.remove('badge-warning');
                        badge.classList.add('badge-success');
                        badge.textContent = 'READ';
                    }
                });
        }
    }

    function closeModal() {
        document.getElementById('inquiryModal').style.display = 'none';
    }

    // Close on click outside
    window.onclick = function(event) {
        const modal = document.getElementById('inquiryModal');
        if (event.target == modal) {
            closeModal();
        }
    }
</script>
