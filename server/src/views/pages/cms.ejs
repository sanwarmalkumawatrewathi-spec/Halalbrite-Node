<div class="card">
    <div class="card-header">
        <h3>Static Pages (CMS)</h3>
        <a href="/admin/cms/add" class="btn btn-primary btn-sm"><i class="fa-solid fa-plus"></i> Add New Page</a>
    </div>
    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>Page Title</th>
                    <th>Slug</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (pages.length === 0) { %>
                    <tr><td colspan="3" class="text-center text-muted" style="padding: 3rem;">No static pages found.</td></tr>
                <% } else { %>
                    <% pages.forEach(page => { %>
                        <tr>
                            <td><span class="customer-name"><%= page.title %></span></td>
                            <td class="text-muted"><code>/<%= page.slug %></code></td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <a href="/admin/cms/edit/<%= page._id %>" class="btn btn-sm btn-ghost" title="Edit"><i class="fa-solid fa-pen-to-square"></i></a>
                                    <form action="/admin/cms/delete/<%= page._id %>" method="POST" onsubmit="return confirm('Delete page?')">
                                        <button type="submit" class="btn btn-sm btn-ghost" style="color: var(--danger);"><i class="fa-solid fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
