<div class="card">
    <div class="card-header">
        <h3 style="font-size: 1.1rem; color: var(--dark);">Edit Profile</h3>
    </div>
    <div style="padding: 2rem;">
        <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success" style="padding: 1rem; background: #dcfce7; color: #166534; border-radius: 8px; margin-bottom: 1.5rem;">
                <i class="fa-solid fa-circle-check"></i> <%= success %>
            </div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger" style="padding: 1rem; background: #fee2e2; color: #991b1b; border-radius: 8px; margin-bottom: 1.5rem;">
                <i class="fa-solid fa-circle-exclamation"></i> <%= error %>
            </div>
        <% } %>

        <form action="/admin/profile/update" method="POST">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div class="form-group">
                    <label>Username</label>
                    <input type="text" name="username" value="<%= user.username %>" class="form-control" required>
                </div>
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" name="email" value="<%= user.email %>" class="form-control" required>
                </div>
            </div>

            <div class="form-group" style="max-width: 50%;">
                <label>New Password (Leave blank to keep current)</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••">
            </div>

            <div style="margin-top: 3rem; text-align: left; border-top: 1px solid var(--light-gray); padding-top: 2rem;">
                <button type="submit" class="btn btn-primary" style="padding-left: 3rem; padding-right: 3rem;">
                    Update Profile
                </button>
            </div>
        </form>
    </div>
</div>
