<div class="form-container">
    <div class="form-header flex justify-between items-center">
        <div>
            <h3 class="form-title">
                <%= faq ? 'Edit FAQ' : 'Add New FAQ' %>
            </h3>
            <p class="form-subtitle">Manage frequently asked questions and help content</p>
        </div>
        <a href="/admin/faqs" class="form-btn-cancel text-sm">Back to List</a>
    </div>

    <form action="/admin/faqs/save" method="POST" class="space-y-8">
        <% if (faq) { %>
            <input type="hidden" name="id" value="<%= faq._id %>">
        <% } %>

        <div class="form-section">
            <span class="section-label">Content Settings</span>
            <div class="form-group">
                <label class="form-label">FAQ Category</label>
                <select name="category" class="form-select" required>
                    <option value="General" <%= faq && faq.category === 'General' ? 'selected' : '' %>>General</option>
                    <option value="Organizer" <%= faq && faq.category === 'Organizer' ? 'selected' : '' %>>Organizer</option>
                    <option value="Attendee" <%= faq && faq.category === 'Attendee' ? 'selected' : '' %>>Attendee</option>
                    <option value="Payments" <%= faq && faq.category === 'Payments' ? 'selected' : '' %>>Payments</option>
                    <option value="Security" <%= faq && faq.category === 'Security' ? 'selected' : '' %>>Security</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Question</label>
                <input type="text" name="question" value="<%= faq ? faq.question : '' %>" 
                    class="form-input" placeholder="Enter question here..." required>
            </div>

            <div class="form-group">
                <label class="form-label">Answer</label>
                <textarea name="answer" class="form-textarea" rows="6" 
                    placeholder="Provide a detailed answer..." required><%= faq ? faq.answer : '' %></textarea>
            </div>
        </div>

        <div class="form-section">
            <span class="section-label">Display & Visibility</span>
            <div class="form-grid-2">
                <div class="form-group">
                    <label class="form-label">Display Order</label>
                    <input type="number" name="order" value="<%= faq ? faq.order : 0 %>" class="form-input">
                    <p class="form-hint">Higher numbers appear later in the list.</p>
                </div>
                <div class="form-group">
                    <label class="form-label">Status</label>
                    <label class="form-checkbox-card">
                        <input type="checkbox" name="isActive" <%= (faq && !faq.isActive) ? '' : 'checked' %> class="w-5 h-5 accent-primary">
                        <span>Active / Visible on site</span>
                    </label>
                </div>
            </div>
        </div>

        <div class="flex justify-end pt-8 border-t border-slate-100 form-footer">
            <button type="submit" class="form-btn-submit">
                <%= faq ? 'Update FAQ' : 'Create FAQ' %>
            </button>
        </div>
    </form>
</div>
