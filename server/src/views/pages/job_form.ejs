<div class="form-container">
    <div class="form-header flex justify-between items-center">
        <div>
            <h3 class="form-title">
                <%= job ? 'Edit Job Position' : 'Add New Job' %>
            </h3>
            <p class="form-subtitle">Post new career opportunities on the platform</p>
        </div>
        <a href="/admin/jobs" class="form-btn-cancel text-sm">Back to List</a>
    </div>

    <form action="/admin/jobs/save" method="POST" class="space-y-8">
        <% if (job) { %>
            <input type="hidden" name="id" value="<%= job._id %>">
        <% } %>

        <div class="form-section">
            <span class="section-label">Job Details</span>
            <div class="form-grid-2">
                <div class="form-group">
                    <label class="form-label" for="title">Job Title</label>
                    <input type="text" id="title" name="title" value="<%= job ? job.title : '' %>" 
                        class="form-input" placeholder="e.g. Senior Full Stack Developer" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="department">Department</label>
                    <input type="text" id="department" name="department" value="<%= job ? job.department : '' %>" 
                        class="form-input" placeholder="e.g. Engineering" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="location">Location</label>
                    <input type="text" id="location" name="location" value="<%= job ? job.location : '' %>" 
                        class="form-input" placeholder="e.g. Remote (Europe)" required>
                </div>

                <div class="form-group">
                    <label class="form-label" for="type">Employment Type</label>
                    <select id="type" name="type" class="form-select" required>
                        <option value="Full-time" <%= job && job.type === 'Full-time' ? 'selected' : '' %>>Full-time</option>
                        <option value="Part-time" <%= job && job.type === 'Part-time' ? 'selected' : '' %>>Part-time</option>
                        <option value="Contract" <%= job && job.type === 'Contract' ? 'selected' : '' %>>Contract</option>
                        <option value="Internship" <%= job && job.type === 'Internship' ? 'selected' : '' %>>Internship</option>
                        <option value="Freelance" <%= job && job.type === 'Freelance' ? 'selected' : '' %>>Freelance</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label" for="status">Status</label>
                    <select id="status" name="status" class="form-select" required>
                        <option value="active" <%= job && job.status === 'active' ? 'selected' : '' %>>Active</option>
                        <option value="inactive" <%= job && job.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label" for="applicationLink">Application Link (Optional)</label>
                    <input type="text" id="applicationLink" name="applicationLink" value="<%= job ? job.applicationLink : '' %>" 
                        class="form-input" placeholder="e.g. https://forms.gle/..." >
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="description">Short Description</label>
                <textarea id="description" name="description" class="form-textarea" rows="3" 
                    placeholder="Brief overview of the role..." required><%= job ? job.description : '' %></textarea>
            </div>

            <div class="form-group">
                <label class="form-label" for="requirements">Requirements (One per line)</label>
                <textarea id="requirements" name="requirements" class="form-textarea" rows="6" 
                    placeholder="5+ years experience&#10;Strong React skills&#10;..." required><%= job ? job.requirements.join('\n') : '' %></textarea>
                <p class="form-hint">Each line will appear as a bullet point with a checkmark in the frontend.</p>
            </div>
        </div>

        <div class="flex justify-end pt-8 border-t border-slate-100 form-footer gap-4">
            <button type="submit" class="form-btn-submit">
                <%= job ? 'Update' : 'Create' %> Position
            </button>
        </div>
    </form>
</div>
