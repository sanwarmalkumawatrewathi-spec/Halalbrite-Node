<div class="card">
    <div class="card-header">
        <h3 style="font-size: 1.1rem; color: var(--dark);">
            <%= page ? 'Edit SEO for Static Page' : 'SEO for Page' %>
        </h3>
        <a href="/admin/cms" class="btn btn-ghost">Back to List</a>
    </div>
    <div style="padding: 2rem;">
        <form action="/admin/cms/save" method="POST" id="cmsForm">
            <% if (page) { %>
                <input type="hidden" name="id" value="<%= page._id %>">
            <% } %>

            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
                <div class="form-group">
                    <label>Page Title</label>
                    <input type="text" name="title" value="<%= page ? page.title : '' %>" class="form-control" placeholder="e.g., About Us, Refund Policy" required>
                </div>
                <div class="form-group">
                    <label>URL Slug</label>
                    <input type="text" name="slug" value="<%= page ? page.slug : '' %>" class="form-control" placeholder="e.g., about-us" required>
                    <small style="color: var(--gray);">URL: /<%= page ? page.slug : 'slug' %></small>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 1.5rem; padding: 1.5rem; border-radius: 12px; border: 1px solid var(--border, rgba(255,255,255,0.1));">
                <div>
                    <h4 style="margin-bottom: 1rem; color: var(--dark); font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">SEO Settings</h4>
                    <div class="form-group">
                        <label>Meta Title</label>
                        <input type="text" name="metaTitle" value="<%= page ? page.metaTitle : '' %>" class="form-control" placeholder="SEO Title">
                    </div>
                    <div class="form-group" style="margin-top: 1rem;">
                        <label>Meta Description</label>
                        <textarea name="metaDescription" class="form-control" rows="3" placeholder="SEO Description"><%= page ? page.metaDescription : '' %></textarea>
                    </div>
                    <div class="form-group" style="margin-top: 1rem;">
                        <label>Meta Keywords</label>
                        <input type="text" name="metaKeywords" value="<%= page ? page.metaKeywords : '' %>" class="form-control" placeholder="Keywords, separated, by, commas">
                    </div>
                </div>
                <div>
                    <h4 style="margin-bottom: 1rem; color: var(--dark); font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Menu Settings</h4>
                    <div class="form-group flex-row" style="display: flex; align-items: center; gap: 10px; margin-bottom: 1rem;">
                        <input type="checkbox" name="showInMenu" id="showInMenu" <%= page && page.showInMenu ? 'checked' : '' %> style="width: 18px; height: 18px;">
                        <label for="showInMenu" style="margin-bottom: 0;">Show in Footer Menu</label>
                    </div>
                    <div class="form-group">
                        <label>Menu Location</label>
                        <select name="menuLocation" class="form-control">
                            <option value="none" <%= page && page.menuLocation === 'none' ? 'selected' : '' %>>None</option>
                            <option value="company" <%= page && page.menuLocation === 'company' ? 'selected' : '' %>>Company</option>
                            <option value="support" <%= page && page.menuLocation === 'support' ? 'selected' : '' %>>Support</option>
                        </select>
                    </div>
                </div>
            </div>



            <% if (page) { %>
                <div style="padding: 1rem; border-radius: 6px; margin-bottom: 2rem; font-size: 0.8rem; color: var(--gray); border: 1px solid var(--border, rgba(255,255,255,0.1));">
                    <i class="fa-solid fa-clock-rotate-left"></i> Last updated: <%= new Date(page.updatedAt).toLocaleString() %>
                </div>
            <% } %>

            <div style="text-align: right; margin-top: 2rem; border-top: 1px solid var(--light-gray); padding-top: 1.5rem;">
                <button type="submit" class="btn btn-primary" style="padding-left: 3rem; padding-right: 3rem;">
                    Update SEO Settings
                </button>
            </div>
        </form>
    </div>
</div>



<style>
    .form-group label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: var(--dark);
    }
</style>
