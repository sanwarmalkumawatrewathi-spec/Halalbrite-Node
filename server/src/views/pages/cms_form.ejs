<div class="form-container">
    <div class="form-header flex justify-between items-center">
        <div>
            <h3 class="form-title">
                <%= page ? 'Edit Page Settings' : 'Page Settings' %>
            </h3>
            <p class="form-subtitle">Configure SEO and menu visibility for static pages</p>
        </div>
        <a href="/admin/cms" class="form-btn-cancel text-sm">Back to List</a>
    </div>

    <form action="/admin/cms/save" method="POST" id="cmsForm" class="space-y-8">
        <% if (page) { %>
            <input type="hidden" name="id" value="<%= page._id %>">
            <% } %>

                <div class="form-section">
                    <span class="section-label">General Information</span>
                    <div class="form-grid-2">
                        <div class="form-group">
                            <label class="form-label">Page Title</label>
                            <input type="text" name="title" value="<%= page ? page.title : '' %>" class="form-input"
                                placeholder="e.g., About Us, Refund Policy" required>
                        </div>
                        <div class="form-group">
                            <label class="form-label">URL Slug</label>
                            <input type="text" name="slug" value="<%= page ? page.slug : '' %>" class="form-input"
                                placeholder="e.g., about-us" required>
                            <p class="form-hint">URL: /<%= page ? page.slug : 'slug' %>
                            </p>
                        </div>
                    </div>
                </div>

                <div class="form-section">
                    <span class="section-label">SEO & Menu Settings</span>
                    <div class="form-subsection-grid">
                        <div>
                            <h4 class="form-subsection-title">SEO Settings</h4>
                            <div class="form-group">
                                <label class="form-label">Meta Title</label>
                                <input type="text" name="metaTitle" value="<%= page ? page.metaTitle : '' %>"
                                    class="form-input" placeholder="SEO Title">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Meta Description</label>
                                <textarea name="metaDescription" class="form-textarea" rows="3"
                                    placeholder="SEO Description"><%= page ? page.metaDescription : '' %></textarea>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Meta Keywords</label>
                                <input type="text" name="metaKeywords" value="<%= page ? page.metaKeywords : '' %>"
                                    class="form-input" placeholder="Keywords, separated, by, commas">
                            </div>
                        </div>

                        <div>
                            <h4 class="form-subsection-title">Menu Settings</h4>
                            <label class="form-checkbox-card" style="margin-bottom: 1.5rem;">
                                <input type="checkbox" name="showInMenu" id="showInMenu" <%=page && page.showInMenu
                                    ? 'checked' : '' %> class="w-5 h-5 accent-primary">
                                <span>Show in Footer Menu</span>
                            </label>
                            <div class="form-group">
                                <label class="form-label">Menu Location</label>
                                <select name="menuLocation" class="form-select">
                                    <option value="none" <%=page && page.menuLocation==='none' ? 'selected' : '' %>>None
                                    </option>
                                    <option value="company" <%=page && page.menuLocation==='company' ? 'selected' : '' %>
                                        >Company</option>
                                    <option value="support" <%=page && page.menuLocation==='support' ? 'selected' : '' %>
                                        >Support</option>
                                </select>
                            </div>

                            <% if (page) { %>
                                <div class="form-hint" style="padding: 1rem; border-radius: 12px; background: #f8fafc; border: 1px solid #e2e8f0;">
                                    <i class="fa-solid fa-clock-rotate-left"></i>
                                    Last updated: <%= new Date(page.updatedAt).toLocaleString() %>
                                </div>
                                <% } %>
                        </div>
                    </div>
                </div>

                <div class="form-footer">
                    <button type="submit" class="form-btn-submit">
                        Update Settings
                    </button>
                </div>
    </form>
</div>
