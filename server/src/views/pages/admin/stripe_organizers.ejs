<%- contentFor('style') %>
    <style>
    </style>

    <%- contentFor('body') %>

        <div class="card" style="margin-bottom: 24px;">
            <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
                <div>
                    <h3 style="margin: 0;">Connected Organisers</h3>
                    <p class="text-muted" style="margin: 4px 0 0 0; font-size: 0.875rem;">Manage Stripe Connect integration for platform organizers</p>
                </div>
                <div style="display: flex; gap: 8px;">
                    <a href="/admin/users/add?role=organizer" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-plus"></i> Add New Organiser
                    </a>
                    <a href="/admin/stripe/dashboard" class="btn btn-outline btn-sm">
                        <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
                    </a>
                </div>
            </div>
        </div>

        <!-- Search & Filter Card -->
        <div class="form-container" style="margin-top: 24px; margin-bottom: 24px;">
            <form method="GET" action="/admin/stripe/organizers">
                <div class="admin-filter-bar">
                    <div class="filter-field filter-field--wide">
                        <label class="form-label" style="font-size: 0.75rem; text-transform: uppercase;">Search Organizer</label>
                        <div style="position: relative;">
                            <span style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted);">
                                <i class="fa-solid fa-magnifying-glass"></i>
                            </span>
                            <input type="text" name="search" value="<%= typeof filters !== 'undefined' ? filters.search : '' %>" placeholder="Search by name or email..." class="form-input" style="padding-left: 36px;" />
                        </div>
                    </div>
                    <div class="filter-field filter-field--wide">
                        <label class="form-label" style="font-size: 0.75rem; text-transform: uppercase;">Organizer Email</label>
                        <div style="position: relative;">
                            <span style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted);">
                                <i class="fa-solid fa-envelope"></i>
                            </span>
                            <input type="text" name="email" value="<%= typeof filters !== 'undefined' ? filters.email : '' %>" placeholder="Filter by email address..." class="form-input" style="padding-left: 36px;" />
                        </div>
                    </div>
                    <div class="filter-actions">
                        <% if (typeof filters !== 'undefined' && (filters.search || filters.email)) { %>
                            <a href="/admin/stripe/organizers" class="form-btn-cancel" style="text-decoration: none; display: inline-flex; align-items: center; gap: 6px;">
                                <i class="fa-solid fa-rotate-left"></i> Reset
                            </a>
                        <% } %>
                        <button type="submit" class="form-btn-submit" style="display: inline-flex; align-items: center; gap: 6px; border: none; cursor: pointer;">
                            <i class="fa-solid fa-filter"></i> Filter
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="form-container">
            <div class="form-section-card" style="padding: 0; overflow: hidden;">
                <div class="table-responsive">
                    <table class="modern-table" style="margin-bottom: 0;">
                        <thead>
                            <tr>
                                <th style="padding: 16px 24px;">ID</th>
                                <th style="padding: 16px 24px;">NAME</th>
                                <th style="padding: 16px 24px;">EMAIL</th>
                                <th style="padding: 16px 24px;">STATUS</th>
                                <th style="padding: 16px 24px;">ACCOUNT ID</th>
                                <th style="padding: 16px 24px;">BALANCE</th>
                                <th style="padding: 16px 24px; text-align: right;">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (organizers && organizers.length> 0) { %>
                                <% organizers.forEach((org, idx)=> { %>
                                    <tr style="border-bottom: 1px solid var(--form-border);">
                                        <td class="text-slate-500" style="padding: 16px 24px; font-family: monospace;">
                                            <%= idx + 1 %>
                                        </td>
                                        <td style="padding: 16px 24px;"><strong class="text-slate-900"
                                                style="font-size: 0.95rem;">
                                                <%= org.username %>
                                            </strong></td>
                                        <td class="text-slate-600" style="padding: 16px 24px;">
                                            <div style="font-weight: 500;"><%= org.email %></div>
                                            <% if (org.stripe_account_email && org.stripe_account_email !== org.email) { %>
                                                <div style="font-size: 0.8rem; color: #64748b; margin-top: 4px; display: flex; align-items: center; gap: 4px;">
                                                    <i class="fa-brands fa-stripe" style="color: #6366f1; font-size: 1.1rem;"></i> <%= org.stripe_account_email %>
                                                </div>
                                            <% } %>
                                        </td>
                                        <td style="padding: 16px 24px;">
                                            <% if (org.accountId || org.stripeConnectedId || org.stripe_account_id) { %>
                                                <span class="badge badge-premium badge-success">CONNECTED</span>
                                                <% } else { %>
                                                    <span class="badge badge-premium badge-danger">PENDING</span>
                                                    <% } %>
                                        </td>
                                        <td class="text-slate-500"
                                            style="padding: 16px 24px; font-family: monospace; font-size: 0.8rem;">
                                            <%= org.accountId || org.stripeConnectedId || org.stripe_account_id || '-'
                                                %>
                                        </td>
                                        <td class="text-slate-900" style="padding: 16px 24px; font-weight: 800;">£<%=
                                                (org.availableBalance || 0).toFixed(2) %>
                                        </td>
                                        <td style="padding: 16px 24px;">
                                            <div class="flex justify-end gap-3">
                                                <% if (org.accountId || org.stripeConnectedId || org.stripe_account_id) { %>
                                                    <a href="/admin/stripe/login-link/<%= org._id %>" target="_blank"
                                                        class="text-indigo-600"
                                                        style="font-weight: 700; font-size: 0.85rem;"
                                                        title="Dashboard">Dashboard</a>
                                                <% } else { %>
                                                    <span class="text-slate-400 cursor-not-allowed"
                                                        style="font-weight: 700; font-size: 0.85rem;"
                                                        title="No Stripe account connected">Dashboard</span>
                                                <% } %>
                                                <a href="/admin/stripe/transactions?organizer=<%= org._id %>"
                                                    class="text-slate-600" style="font-weight: 700; font-size: 0.85rem;"
                                                    title="History">History</a>
                                                <a href="/admin/users/edit/<%= org._id %>" class="text-slate-600"
                                                    style="font-weight: 700; font-size: 0.85rem;"
                                                    title="Profile">Profile</a>
                                                <form id="delete-form-<%= org._id %>" action="/admin/users/delete/<%= org._id %>?redirect=/admin/stripe/organizers" method="POST" style="margin: 0;">
                                                    <button type="button" onclick="confirmDelete('<%= org._id %>')" class="text-red-600"
                                                        style="font-weight: 700; font-size: 0.85rem; border: none; background: none; cursor: pointer;"
                                                        title="Delete">Delete</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="7" class="text-slate-500"
                                                    style="padding: 60px 24px; text-align: center;">
                                                    <i class="fa-solid fa-user-slash"
                                                        style="font-size: 32px; display: block; margin-bottom: 16px; opacity: 0.3;"></i>
                                                    No connected organizers found.
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

<!-- Custom Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 z-[9999] hidden">
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative w-full max-w-md transform overflow-hidden rounded-[2.5rem] bg-white p-8 text-left shadow-2xl transition-all animate-in zoom-in-95 duration-300">
            <button onclick="closeDeleteModal()" class="absolute right-8 top-8 text-slate-400 hover:text-slate-600 transition-colors">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
            <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-red-50 mb-6">
                <i class="fa-solid fa-triangle-exclamation text-3xl text-red-500"></i>
            </div>
            <div class="text-center mb-8 px-4">
                <h3 class="text-2xl font-bold text-slate-900 mb-2">Delete Organizer?</h3>
                <p class="text-slate-500">Are you sure you want to delete this organizer profile? This action cannot be undone and all associated data will be removed.</p>
            </div>
            <div class="flex flex-col sm:flex-row gap-3">
                <button onclick="closeDeleteModal()" class="flex-1 px-6 py-4 rounded-2xl bg-slate-100 text-slate-700 font-bold hover:bg-slate-200 transition-all active:scale-[0.98]">
                    Cancel
                </button>
                <button id="confirmDeleteBtn" class="flex-1 px-6 py-4 rounded-2xl bg-red-600 text-white font-bold hover:bg-red-700 shadow-lg shadow-red-200 transition-all active:scale-[0.98]">
                    Yes, Delete
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let formToSubmit = null;
    function confirmDelete(userId) {
        formToSubmit = document.getElementById(`delete-form-${userId}`);
        const modal = document.getElementById('deleteModal');
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }
    function closeDeleteModal() {
        const modal = document.getElementById('deleteModal');
        modal.classList.add('hidden');
        document.body.style.overflow = 'auto';
        formToSubmit = null;
    }
    document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
        if (formToSubmit) {
            formToSubmit.submit();
        }
    });
</script>