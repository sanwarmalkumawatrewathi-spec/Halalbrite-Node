<%- contentFor('style') %>
    <style>
    </style>

    <%- contentFor('body') %>

        <div class="form-header-premium pb-0">
            <div class="header-left">
                <h1 class="page-title">Connected Organisers</h1>
                <p class="page-subtitle">Manage Stripe Connect integration for platform organizers</p>
            </div>
            <div class="header-actions">
                <a href="/admin/stripe/dashboard" class="form-btn-cancel" style="width: auto; padding: 10px 20px;">
                    <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>

        <!-- Search & Filter Card -->
        <div class="form-container" style="margin-top: 24px; margin-bottom: 24px; padding: 24px;">
            <form method="GET" action="/admin/stripe/organizers">
                <div style="display: flex; gap: 16px; align-items: flex-end; flex-wrap: wrap;">
                    <div style="flex: 1; min-width: 250px;">
                        <label style="display: block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px;">Search Organizer</label>
                        <div style="position: relative;">
                            <span style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted);">
                                <i class="fa-solid fa-magnifying-glass"></i>
                            </span>
                            <input type="text" name="search" value="<%= typeof filters !== 'undefined' ? filters.search : '' %>" placeholder="Search by name or email..." style="width: 100%; padding: 10px 14px 10px 36px; border-radius: 8px; border: 1px solid var(--form-border); font-size: 0.875rem; background: var(--input-bg, #fff); color: var(--text-main);" />
                        </div>
                    </div>
                    <div style="flex: 1; min-width: 250px;">
                        <label style="display: block; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px;">Organizer Email</label>
                        <div style="position: relative;">
                            <span style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted);">
                                <i class="fa-solid fa-envelope"></i>
                            </span>
                            <input type="text" name="email" value="<%= typeof filters !== 'undefined' ? filters.email : '' %>" placeholder="Filter by email address..." style="width: 100%; padding: 10px 14px 10px 36px; border-radius: 8px; border: 1px solid var(--form-border); font-size: 0.875rem; background: var(--input-bg, #fff); color: var(--text-main);" />
                        </div>
                    </div>
                    <div style="display: flex; gap: 8px;">
                        <% if (typeof filters !== 'undefined' && (filters.search || filters.email)) { %>
                            <a href="/admin/stripe/organizers" class="form-btn-cancel" style="width: auto; padding: 10px 20px; display: flex; align-items: center; gap: 6px; text-decoration: none; border-radius: 99px;">
                                <i class="fa-solid fa-rotate-left"></i> Reset
                            </a>
                        <% } %>
                        <button type="submit" class="form-btn-submit" style="width: auto; padding: 10px 24px; display: flex; align-items: center; gap: 6px; border-radius: 99px; border: none; cursor: pointer;">
                            <i class="fa-solid fa-filter"></i> Filter
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="form-container">
            <div class="form-section-card" style="padding: 0; overflow: hidden;">
                <div class="table-responsive">
                    <table class="modern-table" style="margin-bottom: 0;">
                        <thead>
                            <tr>
                                <th style="padding: 16px 24px;">ID</th>
                                <th style="padding: 16px 24px;">NAME</th>
                                <th style="padding: 16px 24px;">EMAIL</th>
                                <th style="padding: 16px 24px;">STATUS</th>
                                <th style="padding: 16px 24px;">ACCOUNT ID</th>
                                <th style="padding: 16px 24px;">BALANCE</th>
                                <th style="padding: 16px 24px; text-align: right;">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (organizers && organizers.length> 0) { %>
                                <% organizers.forEach((org, idx)=> { %>
                                    <tr style="border-bottom: 1px solid var(--form-border);">
                                        <td class="text-slate-500" style="padding: 16px 24px; font-family: monospace;">
                                            <%= idx + 1 %>
                                        </td>
                                        <td style="padding: 16px 24px;"><strong class="text-slate-900"
                                                style="font-size: 0.95rem;">
                                                <%= org.username %>
                                            </strong></td>
                                        <td class="text-slate-600" style="padding: 16px 24px;">
                                            <%= org.email %>
                                        </td>
                                        <td style="padding: 16px 24px;">
                                            <% if (org.accountId || org.stripeConnectedId || org.stripe_account_id) { %>
                                                <span class="badge badge-premium badge-success">CONNECTED</span>
                                                <% } else { %>
                                                    <span class="badge badge-premium badge-danger">PENDING</span>
                                                    <% } %>
                                        </td>
                                        <td class="text-slate-500"
                                            style="padding: 16px 24px; font-family: monospace; font-size: 0.8rem;">
                                            <%= org.accountId || org.stripeConnectedId || org.stripe_account_id || '-'
                                                %>
                                        </td>
                                        <td class="text-slate-900" style="padding: 16px 24px; font-weight: 800;">£<%=
                                                (org.availableBalance || 0).toFixed(2) %>
                                        </td>
                                        <td style="padding: 16px 24px;">
                                            <div class="flex justify-end gap-3">
                                                <% if (org.accountId || org.stripeConnectedId || org.stripe_account_id) { %>
                                                    <a href="/admin/stripe/login-link/<%= org._id %>" target="_blank"
                                                        class="text-indigo-600"
                                                        style="font-weight: 700; font-size: 0.85rem;"
                                                        title="Dashboard">Dashboard</a>
                                                <% } else { %>
                                                    <span class="text-slate-400 cursor-not-allowed"
                                                        style="font-weight: 700; font-size: 0.85rem;"
                                                        title="No Stripe account connected">Dashboard</span>
                                                <% } %>
                                                <a href="/admin/stripe/transactions?organizer=<%= org._id %>"
                                                    class="text-slate-600" style="font-weight: 700; font-size: 0.85rem;"
                                                    title="History">History</a>
                                                <a href="/admin/users/edit/<%= org._id %>" class="text-slate-600"
                                                    style="font-weight: 700; font-size: 0.85rem;"
                                                    title="Profile">Profile</a>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="7" class="text-slate-500"
                                                    style="padding: 60px 24px; text-align: center;">
                                                    <i class="fa-solid fa-user-slash"
                                                        style="font-size: 32px; display: block; margin-bottom: 16px; opacity: 0.3;"></i>
                                                    No connected organizers found.
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>