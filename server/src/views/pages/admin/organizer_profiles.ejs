<div class="card mb-6 shadow-sm border-0 rounded-2xl">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-0 rounded-t-2xl px-6"
        style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
        <div>
            <h3 class="mb-1 text-slate-800 font-bold" style="font-size: 1.25rem;">Organiser Profiles</h3>
            <p class="text-slate-500 text-sm mb-0">Manage individual organiser profiles linked to user accounts</p>
        </div>
        <div style="display: flex; gap: 8px;">
            <a href="/admin/organizer-profiles/add" class="btn btn-primary btn-sm rounded-xl px-4 py-2 font-semibold">
                <i class="fa-solid fa-plus mr-2"></i> Add Profile
            </a>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 border-t border-slate-100">
                <thead class="bg-slate-50/80 text-slate-500 text-xs uppercase tracking-wider font-semibold">
                    <tr>
                        <th class="px-6 py-4 border-0">Profile Name</th>
                        <th class="px-6 py-4 border-0">Account Email</th>
                        <th class="px-6 py-4 border-0">Events Count</th>
                        <th class="px-6 py-4 border-0">Status</th>
                        <th class="px-6 py-4 border-0 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="text-sm font-medium text-slate-700">
                    <% if (profiles && profiles.length > 0) { %>
                        <% profiles.forEach(profile => { %>
                            <tr class="hover:bg-slate-50/80 transition-colors border-b border-slate-50 last:border-0">
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center font-bold text-lg shadow-sm border border-indigo-200">
                                            <%= profile.name.charAt(0).toUpperCase() %>
                                        </div>
                                        <div>
                                            <div class="text-slate-900 font-bold"><%= profile.name %></div>
                                            <div class="text-slate-500 text-xs font-normal mt-0.5"><%= profile.slug %></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-slate-600">
                                    <%= profile.user ? profile.user.email : 'Deleted User' %>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-slate-100 text-slate-700 font-bold text-sm">
                                        <%= profile.eventsCount || 0 %>
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <% if (profile.status === 'active') { %>
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-700 border border-emerald-200">
                                            Active
                                        </span>
                                    <% } else { %>
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold bg-slate-100 text-slate-700 border border-slate-200">
                                            Inactive
                                        </span>
                                    <% } %>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <a href="/admin/organizer-profiles/edit/<%= profile._id %>" 
                                           class="w-8 h-8 rounded-lg bg-slate-50 text-slate-600 flex items-center justify-center hover:bg-indigo-50 hover:text-indigo-600 transition-colors shadow-sm border border-slate-200"
                                           title="Edit Profile">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                        <form id="delete-form-<%= profile._id %>" action="/admin/organizer-profiles/delete/<%= profile._id %>" method="POST" class="m-0">
                                            <button type="button" onclick="confirmDelete('<%= profile._id %>')" 
                                                    class="w-8 h-8 rounded-lg bg-slate-50 text-slate-600 flex items-center justify-center hover:bg-red-50 hover:text-red-600 transition-colors shadow-sm border border-slate-200"
                                                    title="Delete Profile">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="px-6 py-16 text-center text-slate-500">
                                <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-slate-50 flex items-center justify-center text-2xl text-slate-300 border border-slate-100">
                                    <i class="fa-regular fa-id-badge"></i>
                                </div>
                                <h4 class="text-lg font-bold text-slate-700 mb-1">No Organiser Profiles Found</h4>
                                <p class="text-sm font-normal">Get started by creating a new organiser profile.</p>
                                <a href="/admin/organizer-profiles/add" class="btn btn-outline btn-sm rounded-xl px-4 py-2 mt-4 inline-flex font-semibold shadow-sm">
                                    Add First Profile
                                </a>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
    <% if (totalPages > 1) { %>
        <div class="card-footer bg-white border-t border-slate-100 px-6 py-4 rounded-b-2xl">
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted small font-medium">Showing page <%= currentPage %> of <%= totalPages %></span>
                <nav>
                    <ul class="pagination pagination-sm mb-0 gap-1">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link rounded-lg font-medium border-slate-200 text-slate-600" href="?page=<%= currentPage - 1 %>">Previous</a>
                        </li>
                        <% for(let i=1; i <= totalPages; i++) { %>
                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                <a class="page-link rounded-lg font-medium <%= currentPage === i ? 'bg-indigo-600 border-indigo-600' : 'border-slate-200 text-slate-600' %>" href="?page=<%= i %>"><%= i %></a>
                            </li>
                        <% } %>
                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link rounded-lg font-medium border-slate-200 text-slate-600" href="?page=<%= currentPage + 1 %>">Next</a>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    <% } %>
</div>

<!-- Custom Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 z-[9999] hidden">
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity"></div>
    <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative w-full max-w-md transform overflow-hidden rounded-[2.5rem] bg-white p-8 text-left shadow-2xl transition-all animate-in zoom-in-95 duration-300">
            <button onclick="closeDeleteModal()" class="absolute right-8 top-8 text-slate-400 hover:text-slate-600 transition-colors">
                <i class="fa-solid fa-xmark text-xl"></i>
            </button>
            <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-red-50 mb-6">
                <i class="fa-solid fa-triangle-exclamation text-3xl text-red-500"></i>
            </div>
            <div class="text-center mb-8 px-4">
                <h3 class="text-2xl font-bold text-slate-900 mb-2">Delete Profile?</h3>
                <p class="text-slate-500">Are you sure you want to delete this organiser profile? Associated events may lose their link to this profile.</p>
            </div>
            <div class="flex flex-col sm:flex-row gap-3">
                <button onclick="closeDeleteModal()" class="flex-1 px-6 py-4 rounded-2xl bg-slate-100 text-slate-700 font-bold hover:bg-slate-200 transition-all active:scale-[0.98]">
                    Cancel
                </button>
                <button id="confirmDeleteBtn" class="flex-1 px-6 py-4 rounded-2xl bg-red-600 text-white font-bold hover:bg-red-700 shadow-lg shadow-red-200 transition-all active:scale-[0.98]">
                    Yes, Delete
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let formToSubmit = null;
    function confirmDelete(id) {
        formToSubmit = document.getElementById(`delete-form-${id}`);
        const modal = document.getElementById('deleteModal');
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }
    function closeDeleteModal() {
        const modal = document.getElementById('deleteModal');
        modal.classList.add('hidden');
        document.body.style.overflow = 'auto';
        formToSubmit = null;
    }
    document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
        if (formToSubmit) {
            formToSubmit.submit();
        }
    });
</script>
