<div class="form-container max-w-4xl mx-auto">
    <div class="form-header flex justify-between items-center mb-8 border-b border-slate-100 pb-6">
        <div>
            <h3 class="form-title text-2xl font-bold text-slate-800">
                <%= profile ? 'Edit Organiser Profile' : 'Add New Organiser Profile' %>
            </h3>
            <p class="form-subtitle text-slate-500 mt-1">Manage public details for this organiser profile</p>
        </div>
        <a href="/admin/organizer-profiles" class="btn btn-outline btn-sm rounded-xl px-4 py-2 font-semibold shadow-sm">
            <i class="fa-solid fa-arrow-left mr-2"></i> Back to List
        </a>
    </div>

    <form action="/admin/organizer-profiles/save" method="POST" class="space-y-8 bg-white p-8 rounded-2xl shadow-sm border border-slate-100">
        <% if (profile) { %>
            <input type="hidden" name="id" value="<%= profile._id %>">
        <% } %>

        <div class="form-section">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-full bg-indigo-100 text-indigo-600 flex items-center justify-center font-bold">1</div>
                <h4 class="text-lg font-bold text-slate-800 m-0">Basic Information</h4>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="form-group mb-0">
                    <label class="form-label block text-sm font-bold text-slate-700 mb-2">Account Email (User) <span class="text-red-500">*</span></label>
                    <select name="user" class="form-select w-full rounded-xl border-slate-200 focus:border-indigo-500 focus:ring-indigo-500 shadow-sm" required>
                        <option value="">Select User Account</option>
                        <% users.forEach(u => { %>
                            <option value="<%= u._id %>" <%= (profile && profile.user && profile.user._id.toString() === u._id.toString()) ? 'selected' : '' %>>
                                <%= u.email %> (<%= u.username %>)
                            </option>
                        <% }) %>
                    </select>
                    <p class="text-xs text-slate-500 mt-2 font-medium"><i class="fa-solid fa-circle-info mr-1 text-indigo-400"></i> Link this profile to an existing platform user account.</p>
                </div>

                <div class="form-group mb-0">
                    <label class="form-label block text-sm font-bold text-slate-700 mb-2">Profile Name <span class="text-red-500">*</span></label>
                    <input type="text" name="name" value="<%= profile ? profile.name : '' %>"
                        class="form-input w-full rounded-xl border-slate-200 focus:border-indigo-500 focus:ring-indigo-500 shadow-sm" placeholder="e.g. HalalBrite Events" required>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="form-group mb-0">
                    <label class="form-label block text-sm font-bold text-slate-700 mb-2">Website</label>
                    <input type="url" name="website" value="<%= profile ? profile.website : '' %>"
                        class="form-input w-full rounded-xl border-slate-200 focus:border-indigo-500 focus:ring-indigo-500 shadow-sm" placeholder="https://example.com">
                </div>

                <div class="form-group mb-0">
                    <label class="form-label block text-sm font-bold text-slate-700 mb-2">Country</label>
                    <input type="text" name="country" value="<%= profile ? profile.country : '' %>"
                        class="form-input w-full rounded-xl border-slate-200 focus:border-indigo-500 focus:ring-indigo-500 shadow-sm" placeholder="e.g. United Kingdom">
                </div>
            </div>

            <div class="form-group">
                <label class="form-label block text-sm font-bold text-slate-700 mb-2">Bio / Description</label>
                <textarea name="bio" rows="4" class="form-textarea w-full rounded-xl border-slate-200 focus:border-indigo-500 focus:ring-indigo-500 shadow-sm resize-none" placeholder="Tell attendees about this organiser..."><%= profile ? profile.bio : '' %></textarea>
            </div>
        </div>

        <div class="form-section pt-6 border-t border-slate-100">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center font-bold">2</div>
                <h4 class="text-lg font-bold text-slate-800 m-0">Social Links</h4>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="form-group mb-0 relative">
                    <label class="form-label block text-sm font-bold text-slate-700 mb-2">Facebook</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-brands fa-facebook text-slate-400"></i>
                        </div>
                        <input type="url" name="facebook" value="<%= profile?.socialLinks?.facebook || '' %>"
                            class="form-input w-full pl-10 rounded-xl border-slate-200 focus:border-indigo-500 focus:ring-indigo-500 shadow-sm" placeholder="https://facebook.com/page">
                    </div>
                </div>

                <div class="form-group mb-0 relative">
                    <label class="form-label block text-sm font-bold text-slate-700 mb-2">Instagram</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-brands fa-instagram text-slate-400"></i>
                        </div>
                        <input type="url" name="instagram" value="<%= profile?.socialLinks?.instagram || '' %>"
                            class="form-input w-full pl-10 rounded-xl border-slate-200 focus:border-indigo-500 focus:ring-indigo-500 shadow-sm" placeholder="https://instagram.com/profile">
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="form-group mb-0 relative">
                    <label class="form-label block text-sm font-bold text-slate-700 mb-2">Twitter / X</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-brands fa-x-twitter text-slate-400"></i>
                        </div>
                        <input type="url" name="twitter" value="<%= profile?.socialLinks?.twitter || '' %>"
                            class="form-input w-full pl-10 rounded-xl border-slate-200 focus:border-indigo-500 focus:ring-indigo-500 shadow-sm" placeholder="https://twitter.com/profile">
                    </div>
                </div>

                <div class="form-group mb-0 relative">
                    <label class="form-label block text-sm font-bold text-slate-700 mb-2">LinkedIn</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fa-brands fa-linkedin text-slate-400"></i>
                        </div>
                        <input type="url" name="linkedin" value="<%= profile?.socialLinks?.linkedin || '' %>"
                            class="form-input w-full pl-10 rounded-xl border-slate-200 focus:border-indigo-500 focus:ring-indigo-500 shadow-sm" placeholder="https://linkedin.com/in/profile">
                    </div>
                </div>
            </div>
        </div>

        <div class="form-section pt-6 border-t border-slate-100">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center font-bold">3</div>
                <h4 class="text-lg font-bold text-slate-800 m-0">Settings</h4>
            </div>

            <div class="form-group max-w-sm">
                <label class="form-label block text-sm font-bold text-slate-700 mb-2">Profile Status</label>
                <select name="status" class="form-select w-full rounded-xl border-slate-200 focus:border-indigo-500 focus:ring-indigo-500 shadow-sm">
                    <option value="active" <%= profile && profile.status === 'active' ? 'selected' : '' %>>Active</option>
                    <option value="inactive" <%= profile && profile.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                </select>
            </div>
        </div>

        <div class="flex items-center justify-end gap-4 pt-8 border-t border-slate-100">
            <a href="/admin/organizer-profiles" class="px-6 py-3 rounded-xl bg-slate-100 text-slate-700 font-bold hover:bg-slate-200 transition-colors">Cancel</a>
            <button type="submit" class="px-8 py-3 rounded-xl bg-indigo-600 text-white font-bold hover:bg-indigo-700 shadow-md shadow-indigo-200 transition-colors">
                <%= profile ? 'Update Profile' : 'Create Profile' %>
            </button>
        </div>
    </form>
</div>
