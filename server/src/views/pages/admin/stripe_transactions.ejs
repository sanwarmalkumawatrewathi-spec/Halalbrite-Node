<%- contentFor('style') %>
    <%- contentFor('body') %>

        <div class="card" style="margin-bottom: 24px;">
            <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
                <div>
                    <h3 style="margin: 0;">Stripe Transactions</h3>
                    <p class="text-muted" style="margin: 4px 0 0 0; font-size: 0.875rem;">Real-time ledger of all platform revenue splits and organizer earnings</p>
                </div>
            </div>
        </div>

        <div class="form-container">
            <!-- Stats Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                <div class="form-section-card mb-2"
                    style="padding: 24px; display: flex; align-items: center; gap: 20px;">
                    <div
                        style="width: 56px; height: 56px; background: #dcfce7; color: #166534; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 24px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
                        <i class="fa-solid fa-piggy-bank"></i>
                    </div>
                    <div>
                        <p class="text-slate-500"
                            style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">
                            Total Platform Earnings</p>
                        <h3 class="text-slate-900" style="font-size: 1.75rem; font-weight: 900; margin: 0;">£<%=
                                (stats.totalRetained || 0).toFixed(2) %>
                        </h3>
                    </div>
                </div>
                <div class="form-section-card mb-2"
                    style="padding: 24px; display: flex; align-items: center; gap: 20px;">
                    <div
                        style="width: 56px; height: 56px; background: #e0e7ff; color: #4338ca; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 24px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
                        <i class="fa-solid fa-receipt"></i>
                    </div>
                    <div>
                        <p class="text-slate-500"
                            style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;">
                            Total Gross Volume</p>
                        <h3 class="text-slate-900" style="font-size: 1.75rem; font-weight: 900; margin: 0;">£<%=
                                (stats.totalAmount || 0).toFixed(2) %>
                        </h3>
                    </div>
                </div>
            </div>

            <div class="form-section-card" style="padding: 0; overflow: hidden;">
                <div class="table-responsive">
                    <table class="modern-table" style="margin-bottom: 0;">
                        <thead>
                            <tr>
                                <th style="padding: 16px 24px;">DATE</th>
                                <th style="padding: 16px 24px;">ORGANIZER</th>
                                <th style="padding: 16px 24px;">EVENT</th>
                                <th style="padding: 16px 24px;">GROSS</th>
                                <th style="padding: 16px 24px;">FEES RETAINED</th>
                                <th style="padding: 16px 24px;">NET ORGANIZER</th>
                                <th style="padding: 16px 24px;">ID</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (transactions.length===0) { %>
                                <tr>
                                    <td colspan="7" class="text-slate-500"
                                        style="padding: 60px 24px; text-align: center;">
                                        <i class="fa-solid fa-receipt"
                                            style="font-size: 32px; display: block; margin-bottom: 16px; opacity: 0.3;"></i>
                                        No transactions recorded yet.
                                    </td>
                                </tr>
                                <% } else { %>
                                    <% transactions.forEach(tx=> { %>
                                        <tr style="border-bottom: 1px solid var(--form-border);">
                                            <td class="text-slate-600" style="padding: 16px 24px; font-size: 0.9rem;">
                                                <%= new Date(tx.createdAt).toLocaleDateString() %>
                                            </td>
                                            <td class="text-slate-900" style="padding: 16px 24px; font-weight: 700;">
                                                <%= tx.organizer_id ? tx.organizer_id.username : 'Deleted User' %>
                                            </td>
                                            <td class="text-slate-600" style="padding: 16px 24px;">
                                                <% if (tx.type === 'payout') { %>
                                                    <span class="badge" style="background: #e0e7ff; color: #4338ca; font-size: 0.75rem; padding: 4px 8px; border-radius: 4px;">Payout/Transfer</span>
                                                <% } else { %>
                                                    <%= tx.event_id ? tx.event_id.title : 'Deleted Event' %>
                                                <% } %>
                                            </td>
                                            <td class="text-slate-900" style="padding: 16px 24px; font-weight: 800;">£
                                                <%= (tx.amount || 0).toFixed(2) %>
                                            </td>
                                            <td style="padding: 16px 24px; color: #10b981; font-weight: 800;">£<%=
                                                    (Math.max(0, (tx.amount || 0) - (tx.organizer_amount || 0))).toFixed(2) %>
                                            </td>
                                            <td class="text-indigo-600" style="padding: 16px 24px; font-weight: 800;">£
                                                <%= (tx.organizer_amount || 0).toFixed(2) %>
                                            </td>
                                            <td style="padding: 16px 24px;"><code class="text-slate-500"
                                                    style="font-size: 0.75rem;">
                                                <% if (tx.type === 'payout') { %>
                                                    <%= tx.stripe_transfer_id ? tx.stripe_transfer_id.substring(0, 12) + '...' : 'System Sync' %>
                                                <% } else { %>
                                                    <%= tx.stripe_payment_intent_id ? tx.stripe_payment_intent_id.substring(0, 12) + '...' : 'Manual/Import' %>
                                                <% } %>
                                            </code>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>