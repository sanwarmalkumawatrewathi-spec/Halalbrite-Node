<div class="form-header-premium">
    <div class="header-left">
        <h1 class="page-title">All Orders & Ticket Sales</h1>
        <p class="page-subtitle">Total Transactions: <%= typeof totalRecords !=='undefined' ? totalRecords :
                orders.length %>
        </p>
    </div>
</div>

<div class="form-container">
    <div class="form-section-card">
        <div class="table-responsive">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Event</th>
                        <th>Ticket Details</th>
                        <th>Amount</th>
                        <th>Revenue Split</th>
                        <th>Status</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (orders.length===0) { %>
                        <tr>
                            <td colspan="7" class="text-center py-12 text-slate-400">
                                <i class="fa-solid fa-receipt text-4xl block mb-4 opacity-20"></i>
                                No orders found yet.
                            </td>
                        </tr>
                        <% } else { %>
                            <% orders.forEach(order=> { %>
                                <tr>
                                    <td>
                                        <div class="customer-info">
                                            <span class="font-bold text-slate-800">
                                                <%= order.customer_name || (order.user_id ? order.user_id.username
                                                    : 'Guest' ) %>
                                            </span><br>
                                            <span class="text-slate-400 text-xs font-mono">
                                                <%= order.customer_email || (order.user_id ? order.user_id.email : '' )
                                                    %>
                                            </span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="font-bold text-slate-700">
                                            <%= order.event_id ? order.event_id.title : (order.event_name
                                                || 'Deleted Event' ) %>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge badge-premium badge-info">
                                            <%= order.ticket_name %> (x<%= order.quantity %>)
                                        </span>
                                    </td>
                                    <td>
                                        <strong class="text-slate-900">
                                            <%= formatPrice(order.amount_total || 0) %>
                                        </strong>
                                    </td>
                                    <td>
                                        <div class="flex flex-col gap-1 text-xs">
                                            <span class="text-slate-500">Platform: <strong class="text-slate-700">
                                                    <%= formatPrice(order.platform_fee || 0) %>
                                                </strong></span>
                                            <span class="text-slate-500">Org: <strong class="text-slate-700">
                                                    <%= formatPrice(order.organizer_amount || 0) %>
                                                </strong></span>
                                        </div>
                                    </td>
                                    <td>
                                        <span
                                            class="badge badge-premium <%= order.payment_status === 'paid' ? 'badge-success' : 'badge-warning' %>">
                                            <%= order.payment_status %>
                                        </span>
                                    </td>
                                    <td>
                                        <div class="flex justify-end">
                                            <a href="/admin/orders/view/<%= order._id %>"
                                                class="p-2 hover:bg-slate-100 rounded-lg text-slate-600 transition-all"
                                                title="Order Details">
                                                <i class="fa-solid fa-circle-info text-lg"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } %>
                </tbody>
            </table>
        </div>

        <% if (typeof totalPages !=='undefined' && totalPages> 1) { %>
            <div class="card-footer-premium">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div class="text-slate-500 text-sm">
                        Showing <%= (typeof currentPage !=='undefined' ? (currentPage - 1) * 20 + 1 : 1) %> to <%=
                                Math.min((typeof currentPage !=='undefined' ? currentPage * 20 : 20), (typeof
                                totalRecords !=='undefined' ? totalRecords : 0)) %> of <%= (typeof totalRecords
                                    !=='undefined' ? totalRecords : 0) %> orders
                    </div>
                    <div style="display: flex; gap: 8px;">
                        <% if (typeof currentPage !=='undefined' && currentPage> 1) { %>
                            <a href="/admin/orders?page=<%= currentPage - 1 %>"
                                class="btn btn-outline btn-sm">Previous</a>
                            <% } %>

                                <% if (typeof currentPage !=='undefined' && typeof totalPages !=='undefined' ) { %>
                                    <% for(let i=Math.max(1, currentPage - 2); i <=Math.min(totalPages, currentPage +
                                        2); i++) { %>
                                        <a href="/admin/orders?page=<%= i %>"
                                            class="btn btn-sm <%= i === currentPage ? 'btn-primary' : 'btn-outline' %>">
                                            <%= i %>
                                        </a>
                                        <% } %>
                                            <% } %>

                                                <% if (typeof currentPage !=='undefined' && typeof totalPages
                                                    !=='undefined' && currentPage < totalPages) { %>
                                                    <a href="/admin/orders?page=<%= currentPage + 1 %>"
                                                        class="btn btn-outline btn-sm">Next</a>
                                                    <% } %>
                    </div>
                </div>
            </div>
            <% } %>
    </div>
</div>