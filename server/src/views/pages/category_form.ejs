<div class="card">
    <div class="card-header">
        <h3 style="font-size: 1.1rem; color: var(--dark);">
            <%= category ? 'Edit Event Category' : 'Add New Category' %>
        </h3>
        <a href="/admin/categories" class="btn" style="background: #f3f4f6;">Back to List</a>
    </div>
    <div style="padding: 2rem;">
        <form action="/admin/categories/save" method="POST">
            <% if (category) { %>
                <input type="hidden" name="id" value="<%= category._id %>">
            <% } %>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <div class="form-group">
                    <label>Category Name</label>
                    <input type="text" name="name" value="<%= category ? category.name : '' %>" class="form-control" placeholder="e.g., Food & Drinks, Spiritual, Seminars" required>
                </div>
                <div class="form-group">
                    <label>Category Slug</label>
                    <input type="text" name="slug" value="<%= category ? category.slug : '' %>" class="form-control" placeholder="e.g., food-and-drinks" required>
                    <small style="color: var(--gray);">Used for search and filtering URLs.</small>
                </div>
            </div>

            <div class="form-group" style="margin-top: 1rem;">
                <label>Category Image URL</label>
                <input type="text" name="image" value="<%= category ? category.image : '' %>" class="form-control" placeholder="URL to category thumbnail image">
            </div>

            <div style="text-align: right; margin-top: 2.5rem; border-top: 1px solid var(--light-gray); padding-top: 1.5rem;">
                <button type="submit" class="btn btn-primary" style="padding-left: 3rem; padding-right: 3rem;">
                    <%= category ? 'Update Category' : 'Create Category' %>
                </button>
            </div>
        </form>
    </div>
</div>
