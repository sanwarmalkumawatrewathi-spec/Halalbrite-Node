<div class="form-container">
    <div class="form-header flex justify-between items-center">
        <div>
            <h3 class="form-title">
                <%= category ? 'Edit Event Category' : 'Add New Category' %>
            </h3>
            <p class="form-subtitle">Create or modify categories for event classification</p>
        </div>
        <a href="/admin/categories" class="form-btn-cancel text-sm">Back to List</a>
    </div>

    <form action="/admin/categories/save" method="POST" class="space-y-8">
        <% if (category) { %>
            <input type="hidden" name="id" value="<%= category._id %>">
        <% } %>

        <div class="form-section">
            <span class="section-label">General Information</span>
            <div class="form-grid-2">
                <div class="form-group">
                    <label class="form-label">Category Name</label>
                    <input type="text" name="name" value="<%= category ? category.name : '' %>" 
                        class="form-input" placeholder="e.g., Food & Drinks, Spiritual, Seminars" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Category Slug</label>
                    <input type="text" name="slug" value="<%= category ? category.slug : '' %>" 
                        class="form-input" placeholder="e.g., food-and-drinks" required>
                    <p class="form-hint">Used for search and filtering URLs.</p>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Category Image URL</label>
                <input type="text" name="image" value="<%= category ? category.image : '' %>" 
                    class="form-input" placeholder="URL to category thumbnail image">
            </div>
        </div>

        <div class="flex justify-end pt-8 border-t border-slate-100">
            <button type="submit" class="form-btn-submit">
                <%= category ? 'Update Category' : 'Create Category' %>
            </button>
        </div>
    </form>
</div>
